              <p rend="right">GETTY (AAT) | glass plate negatives | ID:<ref target="http://vocab.getty.edu/page/aat/300393160">300393160</ref></p>
              <p><code>&lt;!-- ADD Langford-Brooke example --&gt;</code></p></cell>
          </row>
          <row>
            <cell><p rend="right">object | 3D photographic formats</p>
              <p><hi rend="bold">• Format:</hi> Object</p>
              <p><hi rend="bold">• Type:</hi> Jewellery; Cased photograph</p>
              <p><hi rend="bold">• Material(s):</hi> Enamel</p>
              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="object">
<objectType source="#aat" key="300209286">jewellery</objectType>
<objectType source="#aat" key="300127264">cased photograph</objectType>
<supportDesc material="enamel">
<support>
<material source="#aat" key="300178264">Enamel</material>
</support>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
              <p rend="right">GETTY (AAT) | jewellery | ID:<ref target="http://vocab.getty.edu/page/aat/300209286">300209286</ref></p>
              <p rend="right">GETTY (AAT) | cased photographs | ID:<ref target="http://vocab.getty.edu/page/aat/300127264">300127264</ref></p>
              <p rend="right"><hi rend="italic">Photo Jewellery: Portrait of a mother and daughter:</hi> <ref target="https://www.digitalcollections.manchester.ac.uk/view/VS-VPH-00035/1">VPH.35</ref></p></cell>
          </row>
          <row>
            <cell><p rend="right">fragment | amulet</p>
              <p><hi rend="bold">• Format:</hi> Fragment</p>
              <p><hi rend="bold">• Type:</hi> Amulet</p>
              <p><hi rend="bold">• Material(s):</hi> Parchment</p>
              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="fragment">
<objectType source="#aat" key="300266585">amulet</objectType>
<supportDesc material="parchment">
