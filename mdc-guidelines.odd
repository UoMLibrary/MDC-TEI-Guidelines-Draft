        <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material source="#aat" key="300235507">ceramic</material></egXML></p>
        <p rend="right">GETTY (AAT) | ceramic (material) | ID:<ref target="http://vocab.getty.edu/page/aat/300235507">300235507</ref></p>
        <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="ceramic" subtype="faience" source="#aat" key="300010668">faience </material></egXML></p>
        <p rend="right">GETTY (AAT) | faience (earthenware) | ID:<ref target="http://vocab.getty.edu/page/aat/300010668">300010668</ref></p></cell>
    </row>
