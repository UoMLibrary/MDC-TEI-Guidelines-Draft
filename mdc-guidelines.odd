  <cell><p><val>papyrus</val></p>
    <p rend="right">papyrus</p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material source="#aat" key="300055047">papyrus</material></egXML></p>
  <p rend="right">GETTY (AAT) | papyrus (fibre product) | ID:<ref target="http://vocab.getty.edu/page/aat/300014127">300014127</ref></p></cell>
</row>
<row>
  <cell><p><val>parchment</val></p>
    <p rend="right">parchment</p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material source="#aat" key="300011851">parchment</material></egXML></p>
  <p rend="right">GETTY (AAT) | parchment (animal material) | ID:<ref target="http://vocab.getty.edu/page/aat/300011851">300011851</ref></p></cell>
</row>
<row>
  <cell><p><val>plaster</val></p>
    <p rend="right">plaster</p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material source="#aat" key="300014922">plaster</material></egXML></p>
  <p rend="right">GETTY (AAT) | plaster (composite coating) | ID:<ref target="http://vocab.getty.edu/page/aat/300014922">300014922</ref></p></cell>
</row>
<row>
  <cell><p><val>shell</val></p>
    <p rend="right">shell</p>
    <p rend="right">tortoise shell</p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material source="#aat" key="300014922">shell</material></egXML></p>
  <p rend="right">GETTY (AAT) | shell (animal material) | ID:<ref target="http://vocab.getty.edu/page/aat/300011829">300011829</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="shell" subtype="tortoise" source="#aat" key="300011837">tortoise shell</material></egXML></p>
  <p rend="right">GETTY (AAT) | tortoise shell | ID:<ref target="http://vocab.getty.edu/page/aat/300011837">300011837</ref></p></cell>
</row>
<row>
  <cell><p><val>stone</val></p>
    <p rend="right">stone</p>
    <p rend="right">limestone</p>
    <p rend="right">marble</p>
    <p rend="right">gemstone</p>
    <p rend="right">emerald</p>
    <p rend="right">ruby</p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material source="#aat" key="300011176">stone</material></egXML></p>
  <p rend="right">GETTY (AAT) | stone (worked rock) | ID:<ref target="http://vocab.getty.edu/page/aat/300011176">300011176</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="stone" subtype="limestone" source="#aat" key="300011286">limestone</material></egXML></p>
  <p rend="right">GETTY (AAT) | limestone | ID:<ref target="http://vocab.getty.edu/page/aat/300011286">300011286</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="stone" subtype="marble" source="#aat" key="300011443">marble</material></egXML></p>
  <p rend="right">GETTY (AAT) | marble (rock) | ID:<ref target="http://vocab.getty.edu/page/aat/300011443">300011443</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="stone" subtype="gemstone" source="#aat" key="300201964">gemstone</material></egXML></p>
  <p rend="right">GETTY (AAT) | gemstone | ID:<ref target="http://vocab.getty.edu/page/aat/300201964">300201964</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="stone" subtype="emerald" source="#aat" key="300011074">emerald</material></egXML></p>
  <p rend="right">GETTY (AAT) | emerald (mineral) | ID:<ref target="http://vocab.getty.edu/page/aat/300011074">300011074</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="stone" subtype="ruby" source="#aat" key="300011082">ruby</material></egXML></p>
  <p rend="right">GETTY (AAT) | ruby (mineral) | ID:<ref target="http://vocab.getty.edu/page/aat/300011082">300011082</ref></p></cell>
</row>
<row>
  <cell><p><val>textile</val></p>
    <p rend="right">textile</p>
    <p rend="right">canvas</p>
    <p rend="right">cotton</p>
    <p rend="right">fibre</p>
    <p rend="right">silk</p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material source="#aat" key="300231565">textile</material></egXML></p>
  <p rend="right">GETTY (AAT) | textile materials | ID:<ref target="http://vocab.getty.edu/page/aat/300231565">300231565</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="textile" subtype="canvas" source="#aat" key="300014078">canvas</material></egXML></p>
  <p rend="right">GETTY (AAT) | canvas (textile material) | ID:<ref target="http://vocab.getty.edu/page/aat/300014078">300014078</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="textile" subtype="cotton" source="#aat" key="300014067">cotton</material></egXML></p>
  <p rend="right">GETTY (AAT) | cotton (textile) | ID:<ref target="http://vocab.getty.edu/page/aat/300014067">300014067</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="textile" subtype="fibre" source="#aat" key="300014024">fibre</material></egXML></p>
  <p rend="right">GETTY (AAT) | fibre | ID:<ref target="http://vocab.getty.edu/page/aat/300014024">300014024</ref></p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material type="textile" subtype="silk" source="#aat" key="300243428">silk</material></egXML></p>
  <p rend="right">GETTY (AAT) | silk (textile) | ID:<ref target="http://vocab.getty.edu/page/aat/300243428">300243428</ref></p></cell>
</row>
<row>
  <cell><p><val>wood</val></p>
    <p rend="right">wood</p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><material source="#aat" key="300011914">wood</material></egXML></p>
  <p rend="right">GETTY (AAT) | wood (plant) | ID:<ref target="http://vocab.getty.edu/page/aat/300011914">300011914</ref></p></cell>
</row>
<row>
  <cell><p><val>mixed</val></p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[Multiple <material> with appropriate @type | @subtype values, where applicable (see below).]]></egXML></p></cell>
</row>
<row>
  <cell><p><val>unknown</val></p></cell>
  <cell><p><code>N/A | no specific material type identified.</code></p></cell>
</row>
</table>
<p>The textual value within <gi>material</gi> should be capitalised according to its position in the sentence: use uppercase if it appears at the start of a sentence and lowercase if it appears mid‑sentence. Do <hi rend="bold"><hi rend="italic">not</hi></hi> include a full stop within <gi>material</gi>. Where a full stop is required in prose, place it after the closing <gi>material</gi>. When <gi>material</gi> is encoded as a standalone term, whether simple or compound, do <hi rend="bold"><hi rend="italic">not</hi></hi> include a full stop.</p>
<p>References to materials outside <gi>support</gi>, for example in <gi>binding</gi>, <gi>decoNote</gi>, <gi>seal</gi> or other descriptive contexts, should be encoded using <code>&lt;term</code> <code>type="material"&gt;</code>.</p>
<p><att>material</att> on <gi>supportDesc</gi> is constrained by a controlled vocabulary defined in the customised TEI schema and extended through the ODD. Permitted values, such as paper and parchment, appear in the XML editor as a drop-down list. Only these values are valid. Any other value will result in a schema validation error.</p>
<p>Additional values may be introduced where necessary, provided the proposed value is discussed with the Digital Metadata Specialist and checked against the Getty Art &amp; Architecture Thesaurus (AAT). This helps ensure that the new value does not conflict with an existing term or convey an unintended or overlapping meaning. Once approved, a request should be logged in GitHub so that the value can be added to the schema.</p>
<p><hi rend="bold">Multi-word | compound terms</hi></p>
<p>In contexts where more granular or domain-specific classification is required, compound material terms, which are multi-word expressions referring to a single material, for example, palm leaf, may be encoded in camelCase in <att>material</att>, <att>type</att>, and <att>subtype</att>.</p>
<table rend="rules">
  <row>
    <cell><p><hi rend="bold">• Format:</hi> Codex</p>
      <p><hi rend="bold">• Material(s):</hi> Palm leaf (Corypha umbraculifera)</p>
      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<supportDesc material="palmLeaf">
<support>
<material type="palmLeaf" subtype="corypha" source="#aat" key="300375531">palm leaf (Corypha umbraculifera)</material>
</support>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
      <p rend="right">GETTY (AAT) | Corypha umbraculifera (species) | ID: <ref target="http://vocab.getty.edu/page/aat/300375531">300375531</ref></p></cell>
  </row>
</table>
<p>Compound material terms, for example, birch bark, are encoded by placing the broader category in <att>type</att> and the more specific term in <att>subtype</att> within <gi>material</gi>.</p>
<table rend="rules">
  <row>
    <cell><p><hi rend="bold">• Format:</hi> Codex</p>
      <p><hi rend="bold">• Material(s):</hi> Birch bark</p>
      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<supportDesc material="bark">
<support>
<material type="bark" subtype="birch" source="#aat" key="300011851">birch bark</material>
</support>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
      <p rend="right">GETTY (AAT) | birch bark (plant material) | ID: <ref target="http://vocab.getty.edu/page/aat/300379355">300379355</ref></p></cell>
  </row>
</table>
<p><hi rend="bold">Mixed | composite material terms</hi></p>
<p>In contexts where a single item consists of multiple distinct materials, for example, metal, ivory or gemstone that cannot be adequately captured with a single <att>material</att> value, use <att>material</att>=<val>mixed</val> and encode each material component separately using multiple <gi>material</gi>. Where applicable, add <att>type</att> and <att>subtype</att> to clarify each component.</p>
<table rend="rules">
  <row>
    <cell><p rend="right">treasure binding | metal; ivory; gemstone</p>
      <p><hi rend="bold">• Format:</hi> Object</p>
      <p><hi rend="bold">• Type:</hi> Treasure binding</p>
      <p><hi rend="bold">• Material(s):</hi> Metal, ivory, and gemstone.</p>
      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="object">
<objectType source="#aat" key="300417549">treasure binding</objectType>
<supportDesc material="mixed">
<support>
<p><material source="#aat" key="300010900">Metal</material>, <material source="#aat" key="300011857">ivory</material>, and <material type="stone" subtype="gemstone" source="#aat" key="300201964">gemstone</material>.</p>
</support>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
      <p rend="right">GETTY (AAT) | treasure bindings | ID:<ref target="http://vocab.getty.edu/page/aat/300417549">300417549</ref></p>
      <p rend="right">GETTY (AAT) | metal | ID:<ref target="http://vocab.getty.edu/page/aat/300010900">300010900</ref></p>
      <p rend="right">GETTY (AAT) | ivory (material) | ID:<ref target="http://vocab.getty.edu/page/aat/300011857">300011857</ref></p>
      <p rend="right">GETTY (AAT) | gemstone | ID:<ref target="http://vocab.getty.edu/page/aat/300201964">300201964</ref></p></cell>
  </row>
</table>
<p><hi rend="bold"><hi rend="italic">Avoid</hi></hi> encoding multiple separate materials within a single <gi>material</gi>. Use multiple <gi>material</gi> if needed.</p>
<p>Both <att>material</att> and <gi>material</gi> should use a term from a controlled vocabulary.</p>
<p>Descriptive modifiers, such as fine-quality parchment or heavily foxed paper, should <hi rend="bold"><hi rend="italic">not</hi></hi> be included within <gi>material</gi>. Instead, such elaboration should be expressed in the broader <gi>support</gi>. For example:</p>
<p><egXML xmlns="http://www.tei-c.org/ns/Examples"><supportDesc material="paper">
<support>
<p>Fine quality <material source="#aat" key="300014109">paper</material>.</p>
</support>
<!-- additional metadata -->
</supportDesc></egXML></p>
<p>Do <hi rend="bold"><hi rend="italic">not</hi></hi> use <val>chart</val></p>
<p>For all kinds of paper-writing materials, use <att>material</att>=<val>paper</val>.</p>
<p>Do <hi rend="bold"><hi rend="italic">not</hi></hi> use <val>vellum</val>, <val>perg</val>, <val>part</val>, or <val>parch</val></p>
<p>For all kinds of animal-skin writing materials, use <att>material</att>=<val>parchment</val>.</p>
<p>For all photographic prints, use <att>material</att>=<val>paper</val> and <code>&lt;material type="paper" subtype="photographic"</code> use a more specific term, such as albumen paper, only if the paper type is known with certainty <code>&lt;material</code> <code>type="paper" subtype="albumen"&gt;</code>.</p>
<p>When the material of an item or component cannot be determined with confidence, use <code>&lt;supportDesc material="unknown"&gt;</code>. This ensures that uncertainty is explicitly recorded, rather than leaving the material description blank or omitting it entirely. It is appropriate where no identification is possible from the item itself, associated documentation, or visual analysis, where further research may or may not resolve the uncertainty, and where it is important to assert that the material is unknown rather than simply unspecified.</p>
</div>
<div xml:id="watermark">
  <head><code>&lt;watermark&gt;</code> | watermark</head>
  <p rend="definition"><ref target="https://www.tei-c.org/release/doc/tei-p5-doc/en/html/ref-watermark.html"><gi>watermark</gi></ref> <hi rend="italic">(watermark) contains a word or phrase describing a watermark or similar device.</hi></p>
  <p><gi>watermark</gi> is a phrase-level element, typically used within <gi>support</gi>, to describe watermarks in manuscripts, early printed books, and other paper-based materials.</p>
  <p><gi>term</gi> with <att>type</att>=<val>motif</val> should be used within <gi>watermark</gi> to semantically encode the principal motif or design.</p>
  <p>Only one <code>&lt;term</code> <code>type="motif"&gt;</code> should be used per <gi>watermark</gi> unless the watermark clearly features more than one distinct motif.</p>
  <p>Additional visual or contextual details, such as framing elements, decorative features, and orientation, should be described as free text within <gi>watermark</gi> after <gi>term</gi>.</p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><support>
<p><material source="#aat" key="300014109">Paper</material> with watermark on <locus from="d3r" to="d3r">d3r</locus>: <watermark><term type="motif">Anchor</term> in a circle, surmounted by a star</watermark></p>.
</support></egXML></p>
  <p>The textual value within <code>&lt;term</code> <code>type="motif"&gt;</code> must always be capitalised, regardless of its position in the sentence.</p>
  <p>When possible, <gi>ref</gi> should be used to cite or link to an external resource that supports or verifies the identification of a watermark. When encoding watermark descriptions, <gi>ref</gi> is typically used to reference entries in recognised watermark catalogues such as Briquet, Piccard, Gravell, or databases like <ref target="https://www.memoryofpaper.eu">The Memory of Paper</ref>. <att>target</att> should provide a resolvable link (URL or internal ID) that points to the cited source.</p>
  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><support>
<p><material source="#aat" key="300014109">Paper</material> with watermark on <locus from="d3r" to="d3r">d3r</locus>: <watermark><term type="motif">Anchor</term> in a circle, surmounted by a star</watermark> (<ref target="https://memoryofpaper.eu/briquet/?refnr=478">Briquet 478</ref>).</p>
</support></egXML></p>
  <p>Multiple references can be included where a motif corresponds to more than one catalogue entry.</p>
  <p>The following section outlines four structured approaches to encoding watermarks in MDC using <gi>watermark</gi>, ranging from a single identified watermark to more complex cases involving multiple watermarks or advanced imaging.</p>
  <p><hi rend="bold">Single watermark</hi></p>
  <p>A single watermark with a reference to a recognised watermark catalogue.</p>
  <table rend="rules">
    <row>
      <cell><p><hi rend="bold">• Format:</hi> Codex</p>
        <p><hi rend="bold">• Type:</hi> Book</p>
        <p><hi rend="bold">• Material(s):</hi></p>
        <p>Paper with watermark on d3r: Anchor in a circle, surmounted by a star (Briquet 478).</p>
        <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300028051">book</objectType>
<supportDesc material="paper">
<support>
<p><material source="#aat" key=" aat:300014109">Paper</material> with watermark on <locus from="d3r" to="d3r">d3r</locus>: <watermark><term type="motif">Anchor</term> in a circle, surmounted by a star</watermark> (<ref target="https://memoryofpaper.eu/briquet/?refnr=478">Briquet 478</ref>).</p>
</support>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
      </row>
    </table>
    <p>Where identification is unavailable, the core motif may still be encoded using <code>&lt;term</code> <code>type="motif"&gt;</code> without a catalogue reference. This maintains consistency across files.</p>
    <p><hi rend="bold">Multiple watermarks</hi></p>
    <p>When multiple watermarks occur in different parts of an item, use <gi>list</gi> containing one or more <gi>item</gi>, with each <gi>item</gi> representing a single watermark. Each <gi>item</gi> should include <gi>locus</gi> identifying the location of the watermark, <gi>watermark</gi> containing a motif identified using <code>&lt;term</code> <code>type="motif"&gt;</code>, and, where available, <gi>ref</gi> citing a relevant catalogue entry or authority file.</p>
    <table rend="rules">
      <row>
        <cell><p><hi rend="bold">• Format:</hi> Codex</p>
          <p><hi rend="bold">• Type:</hi> Book</p>
          <p><hi rend="bold">• Material(s):</hi> Paper with watermarks.</p>
          <p>Watermarks</p>
          <p>10r Ox, plain or Bull, with three-pointed tail; with turned skull in en-face view (Briquet 2785).</p>
          <p>100r Anchor in a circle, surmounted by a star (Briquet 478).</p>
          <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<objectDesc form="codex">
<objectType source="#aat" key="300028051">book</objectType>
<supportDesc material="paper">
<support>
<p><material source="#aat" key="300014109">Paper</material> with watermarks.
<list>
<head>Watermarks</head>
<item>
<locus from="10r" to="10r">10r</locus> <watermark><term>Ox</term>, plain or <term>Bull</term>, with three-pointed tail; with turned skull in en-face view</watermark> (<ref target=" https://memoryofpaper.eu/briquet/?refnr=2785">Briquet 2785/ref>).
</item>
<item>
<locus from="100r" to="100r">100r</locus>
<watermark><term type="motif">Anchor</term> in a circle, surmounted by a star</watermark> (<ref target="https://memoryofpaper.eu/briquet/?refnr=478">Briquet 478</ref>).
<item>
</list>
</p>
 </support>
<!-- additional metadata -->
</supportDesc>
</objectDesc>]]></egXML></p></cell>
        </row>
      </table>
      <p>This approach allows each watermark to be described separately and associated with its own location and catalogue reference.</p>
      <p><hi rend="bold">Watermarks | advanced imaging</hi></p>
      <p>Watermarks are inherently partially or entirely invisible in standard digital images because they are embedded within the structure of the paper rather than applied to its surface. Advanced imaging techniques, such as transmitted light, raking light, or multispectral imaging, may reveal details that are not otherwise visible. Where such images are available, additional <gi>locus</gi> may be used to reference the corresponding image identifier recorded in the manifest.</p>
      <table rend="rules">
        <row>
          <cell><p><hi rend="bold">• Format:</hi> Codex</p>
            <p><hi rend="bold">• Type:</hi> Book</p>
            <p><hi rend="bold">• Material(s):</hi></p>
            <p>Paper with a watermark revealed on 49r via transmitted light capture: Anchor in a circle, surmounted by a star (Briquet 478).</p>
            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300028051">book</objectType>
<supportDesc material="paper">
<support>
<p><material source="#aat" key="300014109">Paper</material> with a watermark revealed on <locus from="49r-anchor-tl" to="49r-anchor-tl">49r</locus> via transmitted light capture: <watermark><term type="motif">Anchor</term> in a circle, surmounted by a star</watermark> (<ref target="https://memoryofpaper.eu/briquet/?refnr=478">Briquet 478</ref>).</p>
</support>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
          </row>
        </table>
        <p>The <gi>locus</gi> value <val>49r-anchor-tl</val> refers to a specific image identifier recorded in the manifest’s page reference column (typically Column B), corresponding to 49r and showing the watermark under transmitted light.</p>
        <p><att>from</att> and <att>to</att> contain this internal image identifier, <code>49r-anchor-tl</code>, which uniquely identifies the appropriate imaging variant. The textual content of the <gi>locus</gi>, <code>49r</code>, records the leaf on which the watermark occurs.</p>
        <p>The inclusion of the term <code>anchor</code> in the image identifier helps identify the watermark motif and distinguish between multiple watermark images within the same manuscript, particularly where more than one watermark occurs on a single leaf.</p>
        <p>Where more than one watermark of the same motif occurs on a single leaf, an additional distinguishing component, such as <code>1</code> or <code>2</code>, may be added to the identifier, for example, <code>49r-anchor-1-tl</code> and <code>49r-anchor-2-tl</code>.</p>
        <p>The use of consistent suffixes in <gi>locus</gi> identifiers is essential for distinguishing imaging modes and maintaining reliable links between TEI metadata and image files. These suffixes should reflect the imaging technique used to capture a particular variant of a folio or leaf. Recommended suffixes include:</p>
        <p><hi rend="bold"><code>-tl</code></hi> for transmitted light</p>
        <p><hi rend="bold"><code>-uv</code></hi> for ultraviolet illumination</p>
        <p><hi rend="bold"><code>-rti</code></hi> for reflectance transformation imaging</p>
        <p><hi rend="bold"><code>-msi</code></hi> for multispectral imaging</p>
        <p>The above examples offer practical and widely applicable encoding patterns. This is the most straightforward way to encode watermarks. It offers a simple and practical solution. However, depending on a project’s requirements or the level of detail needed, more advanced encoding is possible. The TEI P5 Customization and Encoding Guidelines for Manuscript Description, specifically Section 1.6.4.2.1.1.1.1 Watermarks, outline richer, more structured encoding approaches. While these support detailed representation of features such as motif, position, and dimensions, they involve customised elements and attributes, and may require further definition, refinement, and formalisation.</p>
        <p><hi rend="bold">Databases and catalogues for watermarks</hi></p>
        <p>Several online platforms provide access to structured and richly described collections of watermarks, supporting research in the history of paper, manuscript studies, book history, and related disciplines.</p>
        <p>WZMA <ref target="https://www.wzma.at/wzonlinekataloge.php">Online Databases</ref> (ÖAW</p>
        <p>The Wasserzeichen des Mittelalters (WZMA) project, hosted by the Österreichische Akademie der Wissenschaften (Austrian Academy of Sciences), offers detailed online catalogues of watermarks found in medieval manuscripts.</p>
        <p>WZIS <ref target="https://www.wasserzeichen-online.de/wzis/projekt/oeaw_de.php">Wasserzeichen-Informationssystem</ref></p>
        <p>The Wasserzeichen-Informationssystem (WZIS) is a collaborative and decentralised platform for the systematic documentation of watermarks. Developed with participation from the Austrian Academy of Sciences and German institutions, it enables cross-institutional contributions and harmonised data structures.</p>
        <p><hi rend="italic">Online Portal Bernstein: <ref target="https://www.memoryofpaper.eu">The Memory of Paper</ref></hi></p>
        <p>The Bernstein — The Memory of Paper portal serves as a meta-platform, integrating access to a wide range of watermark databases, including both WZMA and WZIS.</p>
      </div>
      <div xml:id="extent">
        <head><code>&lt;extent&gt;</code> | extent</head>
        <p rend="definition"><ref target="https://www.tei-c.org/release/doc/tei-p5-doc/en/html/ref-extent.html"><gi>extent</gi></ref> <hi rend="italic">(extent) describes the approximate size of a text stored on some carrier medium or of some other object, digital or non-digital, specified in any convenient units.</hi></p>
        <p rend="displayLabel">MDC display label — <hi rend="bold">Extent</hi></p>
        <p><gi>extent</gi> within <gi>supportDesc</gi> is used to record both the quantity of an item and, where appropriate, the size of its components.</p>
        <p>In manuscript description, traditional codicological practice distinguishes between the core leaves of the volume and any endleaves | flyleaves at the front and back, when identifiable. These may be further differentiated according to whether they are original to the manuscript or later additions. Lower-case Roman numerals are used for original endleaves, and Arabic numerals are used for added endleaves and for the core leaves.</p>
        <p>Based on this tradition, various codicological formulas, such as <code>254 leaves (ii+254+i)</code> | <code>ii+254+i</code> | <code>ii+254+i leaves</code> | <code>254 folios (ii+254+i)</code> | <code>ff. 257 (ii+254+i)</code> | <code>254 folios (ii+ 254+i)</code> | <code>254 folios</code> | <code>etc.</code>, have been used to encode the total extent and structural composition of a codex, typically distinguishing between the main text block and any original or later endleaves.</p>
        <p>However, best practice, particularly when retroconverting from catalogues or where detailed structural information is unavailable, is to record only the total number of leaves. A formula such as <code>ii + 254 + i</code> should be simplified to <code>257 leaves</code>.</p>
        <p><gi>extent</gi> must always record the total number of leaves present in the codex as it physically survives, regardless of whether the endleaves are original or later additions. The total should reflect the physical extent of the complete item.</p>
        <p>When a detailed <gi>collation</gi> is supplied, it provides the full codicological breakdown, including the identification of original or modern endleaves. In this case, <gi>extent</gi> may simply state the total number of leaves without repeating the breakdown: <code>&lt;extent&gt;257 leaves&lt;/extent&gt;</code>.</p>
        <p>When a detailed <gi>collation</gi> is unavailable, <gi>extent</gi> may include a simplified breakdown in brackets to show the probable or observed structure of the volume: <code>&lt;extent&gt;257 leaves (ii + 254 + i)&lt;/extent&gt;</code>.</p>
        <p>In all cases, <hi rend="italic">leaves</hi> should be used in preference to <hi rend="italic">folios</hi> or <hi rend="italic">folia</hi> unless specifically describing a foliation. For printed books, extent is conventionally expressed in <hi rend="italic">leaves</hi> rather than <hi rend="italic">pages</hi>. Consistency in terminology across files is important.</p>
        <p>Even in simple cases, machine-readable encoding should be considered the minimum standard. This means using <gi>measure</gi> with <att>quantity</att> and <att>unit</att>.</p>
      </div>
      <div xml:id="measure">
        <head><code>&lt;measure&gt;</code> | measure</head>
        <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-measure.html"><gi>measure</gi></ref> <hi rend="italic">(measure) contains a word or phrase referring to some quantity of an object or commodity, usually comprising a number, a unit, and a commodity name.</hi></p>
        <p><gi>measure</gi> is a phrase-level element, and within <gi>extent</gi>, it is used to encode quantifiable information such as leaves, sheets, membranes, or other countable units.</p>
        <p rend="attHead"><code>@quantity | @unit</code></p>
        <p><att>quantity</att> (quantity) specifies the number of the specified units that comprise the measurement.</p>
        <p><att>unit</att> (unit) specifies the unit of measurement.</p>
        <p>In legacy encoding practice, <att>type</att> was sometimes used in place of <att>unit</att>, for example, <att>type</att>=<val>leaf</val>. Similarly, <gi>num</gi> with <att>value</att> was sometimes used to normalise Roman numerals where catalogues did not distinguish endleaves from the main textblock. Both practices may still be encountered in older files but are <hi rend="bold"><hi rend="italic">not</hi></hi> recommended for current practice.</p>
        <p>The correct approach is to use <gi>measure</gi> with <att>quantity</att> and <att>unit</att>, allowing the numerical value and its unit of measurement to be encoded explicitly.</p>
        <p><hi rend="bold">Level 1 | total + "formula" | <code>&lt;collation&gt;</code> is absent</hi></p>
        <p>Use when no <gi>collation</gi> is available and only a plain statement is required. The total is encoded using <gi>measure</gi>, and the structural formula is retained in brackets.</p>
        <table rend="rules">
          <row>
            <cell><p><hi rend="bold">• Format:</hi> Codex</p>
              <p><hi rend="bold">• Type:</hi> Manuscript</p>
              <p><hi rend="bold">• Material(s):</hi> Parchment</p>
              <p><hi rend="bold">• Extent:</hi> 254 leaves (ii+254+i)</p>
              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300028569">manuscript</objectType>
<supportDesc material="parchment">
<support>
<material source="#aat" key="300011851">Parchment</material>
</support>
<extent>
<measure quantity="257" unit="leaf">257 leaves (ii+254+i)</measure>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
            </row>
          </table>
          <p><hi rend="bold">Level 2 | total only | <code>&lt;collation&gt;</code> is present</hi></p>
          <p>Used when <gi>collation</gi> is recorded separately and need not be repeated, or when structural detail is not available in the source record, as is often the case with MARC-derived metadata. The total number of leaves is encoded using <gi>measure</gi> only.</p>
          <table rend="rules">
            <row>
              <cell><p><hi rend="bold">• Format:</hi> Codex</p>
                <p><hi rend="bold">• Type:</hi> Book</p>
                <p><hi rend="bold">• Material(s):</hi> Paper</p>
                <p><hi rend="bold">• Extent:</hi> 244 leaves</p>
                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300028051">book</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent>
<measure quantity="244" unit="leaf">244 leaves</measure></extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
              </row>
            </table>
            <p><hi rend="bold">Level 3 | best practice</hi></p>
            <p><gi>extent</gi> records both the primary physical unit being described and, where relevant, the quantity of any significant constituent components. Multiple <gi>measure</gi> may therefore be used within a single <gi>extent</gi> to record different aspects of quantity.</p>
            <p>The first <gi>measure</gi> should normally record the principal physical unit of description, such as a volume, roll, or sheet. Additional <gi>measure</gi> may be used to record countable constituent components, such as leaves, membranes, items, or other discrete units that contribute to the physical extent of the resource.</p>
            <p>Examples include a codex containing multiple leaves, a roll comprising multiple membranes, a photograph album containing numerous mounted items, or an archival unit containing multiple discrete documents.</p>
            <p>For a single, standalone item, always use a self-closing <gi>measure</gi>. This avoids redundant display text, such as 1 codex or 1 volume, as the physical format is already declared via <att>form</att> on <gi>objectDesc</gi> and may be further refined using <gi>objectType</gi>. The self-closing <gi>measure</gi> captures structured metadata via <att>quantity</att> and <att>unit</att>, while keeping the output concise and non-repetitive. For example, <code>&lt;measure quantity="1" unit="roll"/&gt;</code> unambiguously encodes a single scroll without requiring a textual value.</p>
            <p>Self-closing <gi>measure</gi>:</p>
            <table rend="rules">
              <row>
                <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><measure quantity="1" unit="volume"/></egXML></p>
                <p>For codices of all kinds, including bound manuscripts, printed books, etc.</p>
                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><measure quantity="1" unit="leaf"/></egXML></p>
                <p>For a single, detached leaf from a codex or bound volume.</p>
                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><measure quantity="1" unit="roll"/></egXML></p>
                <p>For scrolls or continuous paper, or parchment rolls.</p>
                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><measure quantity="1" unit="sheet"/></egXML></p>
                <p>For flat, flexible paper items, including unbound printed sheets or manuscript folios, and photographic formats.</p>
                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><measure quantity="1" unit="object"/></egXML></p>
                <p>For standalone 3D or non-documentary artefacts such as seals, tools, textiles, stereographs, or mounted photographs.</p></cell>
            </row>
          </table>
          <p>Use <att>quantity</att>=<val>1</val> to indicate that a single complete item is being described. The value of <att>unit</att> should reflect the physical structure of the item. For example, use <val>volume</val> for codices. <hi rend="bold"><hi rend="italic">Avoid</hi></hi> deriving <att>unit</att> from <gi>objectType</gi>, as that element refers to the item's semantic category or intellectual function, not its countable physical form.</p>
          <table rend="rules">
            <row>
              <cell><p rend="right">codex | known leaf count</p>
                <p><hi rend="bold">• Format:</hi> Codex</p>
                <p><hi rend="bold">• Type:</hi> Manuscript</p>
                <p><hi rend="bold">• Material(s):</hi> Paper</p>
                <p><hi rend="bold">• Extent:</hi> 244 leaves</p>
                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300028569">manuscript</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent>
<measure quantity="1" unit="volume"/>
<measure quantity="244" unit="leaf">244 leaves</measure>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
              </row>
              <row>
                <cell><p rend="right">roll | known membrane count</p>
                  <p><hi rend="bold">• Format:</hi> Roll</p>
                  <p><hi rend="bold">• Type:</hi> Scroll</p>
                  <p><hi rend="bold">• Material(s):</hi> Parchment</p>
                  <p><hi rend="bold">• Extent:</hi> 12 membranes</p>
                  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<objectDesc form="roll">
<objectType source="#aat" key="300028629">Scroll</objectType>
<supportDesc material="parchment">
<support>
<material source="#aat" key="300011851">Parchment</material>
</support>
<extent>
<measure quantity="1" unit="roll"/><extent>
<measure quantity="12" unit="membrane">12 membranes</measure>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc>]]></egXML></p></cell>
                </row>
              </table>
              <p>In addition to recording physical components such as leaves or membranes, <gi>measure</gi> may also be used to encode the number of contained items using <att>unit</att>=<val>item</val>. This is particularly useful for photograph albums, scrapbooks, archival collections, and other compound resources containing multiple distinct items.</p>
              <p>Containers used solely for storage or housing should <hi rend="bold"><hi rend="italic">not</hi></hi> normally be recorded in <gi>extent</gi>. Where an original, contemporary, or historically significant container forms part of the resource being described, it may be encoded using an additional <gi>measure</gi> with an appropriate <att>unit</att> value, such as <val>folder</val>.</p>
              <table rend="rules">
                <row>
                  <cell><p rend="right">codex | scrapbook with known item count</p>
                    <p><hi rend="bold">• Format:</hi> Codex</p>
                    <p><hi rend="bold">• Type:</hi> Scrapbook</p>
                    <p><hi rend="bold">• Material(s):</hi> Paper</p>
                    <p><hi rend="bold">• Extent:</hi> 274 items</p>
                    <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300027341">scrapbook</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent>
<measure quantity="1" unit="volume"/>
<measure quantity="274" unit="item">274 items</measure>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p rend="right">archival collection | loose material with known item count</p>
                      <p><hi rend="bold">• Format:</hi> Sheet</p>
                      <p><hi rend="bold">• Type:</hi> Archive (grouping)</p>
                      <p><hi rend="bold">• Material(s):</hi> Paper</p>
                      <p><hi rend="bold">• Extent:</hi> 50 items</p>
                      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="sheet">
<objectType source="#aat" key="300375748">archive (grouping)</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent>
<measure quantity="50" unit="item">50 items</measure>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                    </row>
                    <row>
                      <cell><p rend="right">archival collection | loose material in original folder with known item count</p>
                        <p><hi rend="bold">• Format:</hi> Sheet</p>
                        <p><hi rend="bold">• Type:</hi> Archive (grouping)</p>
                        <p><hi rend="bold">• Material(s):</hi> Paper</p>
                        <p><hi rend="bold">• Extent:</hi> 50 items</p>
                        <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300375748">archive (grouping)</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent>
<measure quantity="1" unit="folder"/>
<measure quantity="50" unit="item">50 items</measure>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                      </row>
                    </table>
                    <p>Where the size of leaves (or equivalent unit) is known, it should be encoded using <gi>dimensions</gi>.</p>
                  </div>
                  <div xml:id="dimensions">
                    <head><code>&lt;dimensions&gt;</code> | dimensions</head>
                    <p rend="definition"><ref target="https://www.tei-c.org/release/doc/tei-p5-doc/en/html/ref-dimensions.html"><gi>dimensions</gi></ref> <hi rend="italic">(dimensions) contains a dimensional specification.</hi></p>
                    <p><gi>dimensions</gi> is a phrase-level element and may be used wherever dimensions are recorded. It may be embedded directly in <gi>extent</gi> or placed elsewhere, depending on what is being measured. Typical placements include <gi>binding</gi> for binding size, in <gi>layout</gi> for written or ruled space, and any element where dimensions are relevant.</p>
                    <p>In the context of <gi>extent</gi>, <gi>dimensions</gi> serves as a container for recording measurements of a specified component or aspect of the item. Attributes such as <att>type</att> and <att>unit</att> define the scope of the measurements and the units used, while child elements such as <gi>height</gi>, <gi>width</gi>, and <gi>depth</gi> contain the corresponding values.</p>
                    <p rend="attHead"><code>@type | @unit</code></p>
                    <p><att>type</att> identifies the aspect or component being measured</p>
                    <p><att>unit</att>=<val>mm</val> specifies the unit of measurement in millimetres</p>
                    <p>The <att>unit</att> value must always be given in millimetres (mm) when encoding dimensions, whether cataloguing afresh or retroconverting legacy data, rather than replicating the system used in a source catalogue. The unit of measurement in millimetres (mm) should <hi rend="bold"><hi rend="italic">not</hi></hi> be included in prose, as it is generated by the XSLT transformation.</p>
                    <p><att>type</att> provides a common typology of the dimensions of a given item source. The following values should be used:</p>
                    <p><val>leaf</val> for a single loose leaf from a codex, or more leaves bound in a codex</p>
                    <p><val>roll</val> for a continuous scroll formed from multiple membranes joined together.</p>
                    <p><val>membrane</val> for individual membranes that form the roll, i.e. scroll</p>
                    <p><val>sheet</val> for loose, unbound flat items, such as maps, letters, broadsides, and photographic formats</p>
                    <p><val>envelope</val> for a separate envelope used to house or protect the item.</p>
                    <p><val>mount</val> for mount, backing board, or similar support to which an item (e.g. photographic print) is attached.</p>
                    <p><val>object</val> for the overall dimensions of a complete artefact as a whole</p>
                    <p>Always include <att>type</att> on <gi>dimensions</gi>, even if only one set of dimensions is recorded. Wherever possible, select the most specific <att>type</att> value appropriate to the material or component described.</p>
                  </div>
                  <div xml:id="height-width">
                    <head><code>&lt;height&gt;</code> | height | <code>&lt;width&gt;</code> | width</head>
                    <p rend="definition"><ref target="https://www.tei-c.org/release/doc/tei-p5-doc/en/html/ref-height.html"><gi>height</gi></ref> <hi rend="italic">(height) contains a measurement measured along the axis at a right angle to the bottom of the object.</hi></p>
                    <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-width.html"><gi>width</gi></ref> <hi rend="italic">(width) contains a measurement of an object along the axis parallel to its bottom, e.g. perpendicular to the spine of a book or codex.</hi></p>
                    <p><gi>height</gi> and <gi>width</gi> give vertical and horizontal dimensions. <ref target="https://www.tei-c.org/release/doc/tei-p5-doc/en/html/ref-depth.html">&lt;depth&gt;</ref> may also be used to record thickness, though for codices this is often implied by the number of leaves in <gi>extent</gi>. Where conservation or technical documentation provides a depth measurement, such as the thickness of a binding, this may also be encoded, commonly within <gi>binding</gi>.</p>
                    <p>In legacy encoding practice, dimensions were sometimes encoded solely as plain textual content, for example <code>&lt;height&gt;210&lt;/height&gt;</code> and <code>&lt;width&gt;140&lt;/width&gt;</code>. In other cases, the same values were encoded using <att>n</att>, for example <code>&lt;height n="210"&gt;210&lt;/height&gt;</code> and <code>&lt;width n="140"&gt;140&lt;/width&gt;</code>. While this is valid TEI, since <gi>height</gi> and &lt;<code>width</code>&gt; may <hi rend="italic">contain character data only</hi>, and the use of <att>n</att> is technically permitted, <hi rend="bold"><hi rend="italic">neither</hi></hi> is recommended for recording dimensions. In both cases, the value is treated as unstructured text, with no explicit semantic indication that it represents a physical measurement. Best practice is to use <att>quantity</att> to encode the measurement values explicitly.</p>
                    <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><dimensions type="leaf" unit="mm">
<height quantity="210">210</height>
<width quantity="140">140</width>
</dimensions></egXML></p>
                    <p>The following examples demonstrate how to combine <gi>measure</gi> with <gi>dimensions</gi>, before moving on to cases involving uncertainty, approximate ranges, or partial measurements.</p>
                    <table rend="rules">
                      <row>
                        <cell><p rend="right">codex | uniform leaf size</p>
                          <p><hi rend="bold">• Format:</hi> Codex</p>
                          <p><hi rend="bold">• Type:</hi> Manuscript</p>
                          <p><hi rend="bold">• Material(s):</hi> Paper</p>
                          <p><hi rend="bold">• Extent:</hi> 244 leaves. Leaf height: 210 mm, width: 140 mm.</p>
                          <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300028569">manuscript</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent>
<measure quantity="1" unit="volume"/>
<measure quantity="244" unit="leaf">244 leaves</measure>.
<dimensions type="leaf" unit="mm">
<height quantity="210">210</height>
<width quantity="140">140</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                        </row>
                      </table>
                      <p>A full stop followed by a space must be manually inserted immediately after the closing <gi>measure</gi> if it is followed by <gi>dimensions</gi>. The display of <gi>dimensions</gi>, whether used once or multiple times, is automatically formatted by the system. Capitalisation, such as Leaf height, and punctuation, such as the full stop after width followed by the measurement in millimetres (mm), are generated by the XSLT transformation.</p>
                      <table rend="rules">
                        <row>
                          <cell><p rend="right">single, loose leaf from a codex</p>
                            <p><hi rend="bold">• Format:</hi> Leaf</p>
                            <p><hi rend="bold">• Type:</hi> Manuscript</p>
                            <p><hi rend="bold">• Material(s):</hi> Parchment</p>
                            <p><hi rend="bold">• Extent:</hi> Leaf height: 262 mm, width: 170 mm.</p>
                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300028569">manuscript</objectType>
<supportDesc material="parchment">
<support>
<material source="#aat" key="300011851">Parchment</material>
</support>
<extent>
<measure quantity="1" unit="leaf"/>
<dimensions type="leaf" unit="mm">
<height quantity="262">262</height>
<width quantity="170">170</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
                            <p rend="right">Missing leaf | Psalm 118:71–89:  <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-LATIN-00022/347">Latin MS 22 A</ref></p></cell>
                        </row>
                      </table>
                      <p>Use a self-closing <gi>measure</gi> for a single roll when the number of membranes is known but their individual dimensions are not. Pair this with a second <gi>measure</gi> containing both <att>quantit</att>y and a content value, such as 12 membranes, to support structured metadata and ensure clear display.</p>
                      <table rend="rules">
                        <row>
                          <cell><p rend="right">scroll made of multiple membranes</p>
                            <p rend="right">Case 1: membrane count known, dimensions unknown</p>
                            <p><hi rend="bold">• Format:</hi> Roll</p>
                            <p><hi rend="bold">• Type:</hi> Scroll</p>
                            <p><hi rend="bold">• Material(s):</hi> Parchment</p>
                            <p><hi rend="bold">• Extent:</hi> Roll height: 6401 mm, width: 851 mm.</p>
                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="roll">
<objectType source="#aat" key="300028629">Scroll</objectType>
<supportDesc material="parchment">
<support>
<material source="#aat" key="300011851">Parchment</material>
</support>
<extent>
<measure quantity="1" unit="roll"/>
<dimensions type="roll" unit="mm">
<height quantity="6401">6401</height>
<width quantity="851">851</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
                            <p rend="right">Arbor Caritatis et Misercordiae:  <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-LATIN-00018/1">Latin MS 18</ref></p></cell>
                        </row>
                      </table>
                      <p>When dimensions for the roll and each membrane are available, encode these using separate <gi>dimensions</gi>, clearly specifying <att>type</att>=<val>roll</val> and <att>type</att>=<val>membrane</val> to distinguish the overall object from its components.</p>
                      <table rend="rules">
                        <row>
                          <cell><p rend="right">scroll made of multiple membranes</p>
                            <p rend="right">Case 2: membrane count and dimensions both known</p>
                            <p><hi rend="bold">• Format:</hi> Roll</p>
                            <p><hi rend="bold">• Type:</hi> Scroll</p>
                            <p><hi rend="bold">• Material(s):</hi> Parchment</p>
                            <p><hi rend="bold">• Extent:</hi> 12 membranes. Roll height: 6401 mm, width: 765 mm. Membrane height: 533 mm, width: 765 mm.</p>
                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="roll">
<objectType source="#aat" key="300028629">Scroll</objectType>
<supportDesc material="parchment" >
<support>
<material source="#aat" key="300011851">Parchment</material>
</support>
<extent><measure quantity="1" unit="roll"/>
<measure quantity="12" unit="membrane">12 membranes</measure>.
<dimensions type="roll" unit="mm">
<height quantity="6401">6401</height>
<width quantity="765">765</width>
</dimensions>
<dimensions type="membrane" unit="mm">
<height quantity="533">533</height>
<width quantity="765">765</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                          </row>
                        </table>
                        <p>Sheet size refers to the full physical dimensions of the paper or other support material on which the map is printed, drawn, or mounted. This includes all margins, blank areas, and borders. Map size refers to the extent of the cartographic content itself, excluding margins, borders, and legends, and should be measured to the outermost edges of the map area. Folded size refers to the physical dimensions of the item when folded for issue, handling, or storage.</p>
                        <table rend="rules">
                          <row>
                            <cell><p rend="right">map</p>
                              <p><hi rend="bold">• Format:</hi> Sheet</p>
                              <p><hi rend="bold">• Type:</hi> Map</p>
                              <p><hi rend="bold">• Material(s):</hi> Paper</p>
                              <p><hi rend="bold">• Extent:</hi> Sheet height: 765 mm, width: 607 mm.</p>
                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="sheet">
<objectType source="#aat" key="300028094">map</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent><measure quantity="1" unit="sheet"/>
<dimensions type="sheet" unit="mm">
<height quantity="765">765</height>
<width quantity="607">607</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                            </row>
                          </table>
                          <p>When known, record the dimensions of the cartographic area and the paper support using separate <gi>dimensions</gi> within <gi>extent</gi>, using <att>type</att>=<val>map</val> and <att>type</att>=<val>sheet</val> respectively. This allows the size of the map itself to be distinguished from the size of the supporting sheet.</p>
                          <table rend="rules">
                            <row>
                              <cell><p rend="right">map | sheet size</p>
                                <p><hi rend="bold">• Format:</hi> Sheet</p>
                                <p><hi rend="bold">• Type:</hi> Map</p>
                                <p><hi rend="bold">• Material(s):</hi> Paper</p>
                                <p><hi rend="bold">• Extent:</hi> Map height: 600 mm, width: 440 mm. Sheet height: 710 mm, width: 580 mm.</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="sheet">
<objectType source="#aat" key="300028094">map</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent><measure quantity="1" unit="sheet"/>
<dimensions type="map" unit="mm">
<height quantity="600">600</height>
<width quantity="440">440</width>
</dimensions>
<dimensions type="sheet" unit="mm">
<height quantity="710">710</height>
<width quantity="580">580</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
                                <p rend="right">The Drink Map of Manchester<hi rend="bold">:</hi> <ref target="https://www.digitalcollections.manchester.ac.uk/view/PR-C-00017-00070-MANCHESTER-00003/1">C17:70 Manchester (3)</ref></p></cell>
                            </row>
                          </table>
                          <p>If the dimensions of the item when folded are known, record them using a separate <gi>dimensions</gi> within <gi>extent</gi>, using <code>@type="folded"&gt;</code>. Use <att>type</att>=<val>mount</val> to record the dimensions of a mount supporting the item.</p>
                          <table rend="rules">
                            <row>
                              <cell><p rend="right">map | folded</p>
                                <p><hi rend="bold">• Format:</hi> Sheet</p>
                                <p><hi rend="bold">• Type:</hi> Map</p>
                                <p><hi rend="bold">• Material(s):</hi> Paper</p>
                                <p><hi rend="bold">• Extent:</hi> Sheet height: 353 mm, width: 467 mm. Folded height: 156 mm, width: 88 mm.</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<objectType source="#aat" key="300028094">map</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent><measure quantity="1" unit="sheet"/>
<dimensions type="sheet" unit="mm">
<height quantity="353">353</height>
<width quantity="467">467</width>
</dimensions>
<dimensions type="folded" unit="mm">
<height quantity="156">156</height>
<width quantity="88">88</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
                                <p rend="right">Kaihō Kyō Ezu: <ref target="https://www.digitalcollections.manchester.ac.uk/view/PR-JAPANESE-00048/1">Japanese 48</ref></p></cell>
                            </row>
                          </table>
                          <p>Correspondence letter sheet size refers to the full physical dimensions of the writing paper. Folded size refers to the dimensions of the letter when folded for handling, storage, or self-enclosure. Envelope size refers to the dimensions of a separate envelope, where present.</p>
                          <p>Use <gi>extent</gi> to record both the quantity and the dimensions of a sheet by including a <gi>measure</gi> for quantity and <gi>dimensions</gi> with <code>type="sheet"&gt;</code> for size. If the dimensions of the item when folded are known, record them using a separate <gi>dimensions</gi> with <att>type</att>=<val>folded</val>. Structural or descriptive information, such as folded once to form two leaves, should be recorded as prose within <gi>support</gi>. If a separate envelope is present, record it using <code>&lt;measure unit="envelope"&gt;</code>. Where its dimensions are known, record them using a separate <gi>dimensions</gi> with <att>type</att>=<val>envelope</val>.</p>
                          <table rend="rules">
                            <row>
                              <cell><p rend="right">correspondence letter | single sheet</p>
                                <p><hi rend="bold">• Format:</hi> Sheet</p>
                                <p><hi rend="bold">• Type:</hi> Letter (correspondence)</p>
                                <p><hi rend="bold">• Material(s):</hi> Paper</p>
                                <p><hi rend="bold">• Extent:</hi> Sheet height: 180 mm, width: 230 mm.</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="sheet">
<objectType source="#aat" key="300026879">letter (correspondence)</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent>
<measure quantity="1" unit="sheet"/>
<dimensions type="sheet" unit="mm">
<height quantity="180">180</height>
<width quantity="230">230</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                              </row>
                            </table>
                            <p>Although Level 3 best practice generally recommends using the self-closing <gi>measure</gi> in a display-neutral form without textual value, a non-self-closing <gi>measure</gi> with textual value such as 2 sheets or 12 membranes, must be used when encoding multiple physical components. In these cases, both <att>quantity</att> and the textual value are required.</p>
                            <table rend="rules">
                              <row>
                                <cell><p rend="right">correspondence letter | two sheets</p>
                                  <p><hi rend="bold">• Format:</hi> Sheet</p>
                                  <p><hi rend="bold">• Type:</hi> Letter (correspondence)</p>
                                  <p><hi rend="bold">• Material(s):</hi> Paper</p>
                                  <p><hi rend="bold">• Extent:</hi> 2 Sheets. Sheet height: 256 mm, width: 204 mm.</p>
                                  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="sheet">
<objectType source="#aat" key="300026879">letter (correspondence)</objectType>
<supportDesc material="paper">
<support>
<material source="#aat" key="300014109">Paper</material>
</support>
<extent>
<measure quantity="2" unit="sheet">2 sheets</measure>.
<dimensions type="sheet" unit="mm">
<height quantity="256">256</height>
<width quantity="204">204</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                                </row>
                              </table>
                              <p>For objects such as stereographs and other mounted photographic prints, it is often necessary to record both the dimensions of the photographic sheet and those of the mount or supporting leaf. These measurements should be distinguished using <att>type</att> on <gi>dimensions</gi>. The photographic print should be encoded using <att>type</att>=<val>sheet</val>, while the mount or backing, such as a stereocard, should be encoded using <att>type</att>=<val>mount</val>.</p>
                              <table rend="rules">
                                <row>
                                  <cell><p rend="right">object | stereograph</p>
                                    <p><hi rend="bold">• Format:</hi> Object</p>
                                    <p><hi rend="bold">• Type:</hi> Stereograph</p>
                                    <p><hi rend="bold">• Material(s):</hi> Albumen paper mounted on cardboard.</p>
                                    <p><hi rend="bold">• Extent:</hi> Sheet height: 50 mm, width: 80 mm. Mount height: 90 mm, width: 160 mm.</p>
                                    <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="object">
<objectType source="#aat" key="300127197">stereograph</objectType>
<supportDesc material="paper">
<support>
<material type="paper" subtype="albumen" source="#aat" key="300411855">Albumen paper</material> mounted on <material type="paper" subtype="cardboard" source="#aat" key="300014224">cardboard</material>.
</support>
<extent><measure quantity="1" unit="object"/>
<dimensions type="sheet" unit="mm">
<height quantity="50">50</height>
<width quantity="80">80</width>
</dimensions>
<dimensions type="mount" unit="mm">
<height quantity="90">90</height>
<width quantity="160">160</width>
</dimensions>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p></cell>
                                  </row>
                                </table>
                                <p><hi rend="bold">General remarks: extent and measurements</hi></p>
                                <p>Structured quantitative information, such as counts of sheets, leaves, or enclosures, should be encoded using <gi>measure</gi> with appropriate <att>quantity</att> and <att>unit</att>. Narrative descriptions of physical construction or folding should not be included within <gi>extent</gi>, as this disrupts the structured format.</p>
                                <p>At Level 3, single physical units are normally encoded using a self-closing <gi>measure</gi>, while multi-sheet or display-dependent extents should be encoded using a <gi>measure</gi> containing textual content:</p>
                                <p>single codex, roll, object—self-closing</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><measure quantity="1" unit="volume"/></egXML></p>
                                <p>single sheet (letter or map)—self-closing</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><measure quantity="1" unit="sheet"/></egXML></p>
                                <p>multi-sheet item (letters)—non-self-closing with display text</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<measure quantity="2" unit="sheet>2 sheets</measure>]]></egXML></p>
                                <p>Measurements of ruled or written areas, such as the text block or inscribed space, must be encoded within <gi>layout</gi>, <hi rend="bold"><hi rend="italic">not</hi></hi> <gi>extent</gi>. This information concerns the arrangement of text on the page, not the dimensions of the physical support. Although some catalogues present these measurements alongside leaf size, this approach should not be reproduced in TEI encodings, even for retroconverted files.</p>
                                <p><hi rend="bold">Encoding scope, ranges and uncertainty</hi></p>
                                <p>Measurements are not always exact. Dimensions may vary due to trimming, rebinding, warping, or the presence of added components, and in some cases, direct measurement may not be possible. Measurements may therefore be encoded using additional attributes to represent ranges, approximate values, or estimates. This richer level of detail is particularly valuable where significant variation in size occurs within an item.</p>
                                <p>In legacy encoding practice, the global attributes <att>precision</att> (for measurement accuracy) and <att>cert</att> (for encoder confidence) were sometimes used. Such usage may still be encountered in older records but is <hi rend="bold"><hi rend="italic">not</hi></hi> recommended for current practice. Instead, variation and uncertainty <hi rend="bold"><hi rend="italic">must</hi></hi> be encoded using <att>min</att>, <att>max</att>, <att>atLeast</att>, and <att>atMost</att>.</p>
                                <p rend="attHead"><code>@min | @max | @atLeast | @atMost</code></p>
                                <p><att>min</att> where the measurement summarises more than one observation or a range, supplies the minimum value observed.</p>
                                <p><att>max</att> where the measurement summarises more than one observation or a range, supplies the maximum value observed.</p>
                                <p><att>atLeast</att> gives a minimum estimated value for the approximate measurement.</p>
                                <p><att>atMost</att> gives a maximum estimated value for the approximate measurement.</p>
                                <p><hi rend="bold">Exact, uniform dimensions</hi></p>
                                <p>The item has been measured directly, and all components, such as leaves, membranes, or sheets share the same dimensions with no variation. This includes uniformly trimmed manuscripts and books, single sheet maps, and folded letters where all sides match in size. Do <hi rend="bold"><hi rend="italic">not</hi></hi> use this model if there is any measurable variation within the item. The measurements must be:</p>
                                <p>Known | not estimated or inferred — Exact | taken directly from the physical item — Uniform | the same across all measurable parts</p>
                                <table rend="rules">
                                  <row>
                                    <cell><p><hi rend="bold">• Extent:</hi> 254 leaves. Leaf height: 450 mm, width: 325 mm.</p>
                                      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><extent>
<measure quantity="254" unit="leaf">254 leaves</measure>.
<dimensions type="leaf" unit="mm">
<height quantity="450">450</height>
<width quantity="325">325</width>
</dimensions>
</extent></egXML></p></cell>
                                    </row>
                                  </table>
                                  <p><hi rend="bold">Observed size variation</hi></p>
                                  <p>The item contains components that vary measurably in size, such as leaves of different heights or membranes with uneven widths. If the variation between components exceeds 10 mm, encode the range using <att>min</att> and <att>max</att>. The measurements are:</p>
                                  <p>Observed | derived from direct measurement of parts of the item — Variable | the dimensions differ across the internal structure —</p>
                                  <p>Summarised | as a range spanning all known values</p>
                                  <table rend="rules">
                                    <row>
                                      <cell><p><hi rend="bold">• Extent:</hi> 254 leaves. Leaf height: 205-215 mm, width: 135-145 mm.</p>
                                        <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><extent>
<measure quantity="254" unit="leaf">254 leaves</measure>.
<dimensions type="leaf" unit="mm">
<height min="205" max="215">205-215</height>
<width min="135" max="145">135-145</width>
</dimensions>
</extent></egXML></p></cell>
                                      </row>
                                    </table>
                                    <p>No <att>quantity</att> on <gi>height</gi> or <gi>width</gi>, because we are not asserting an exact size.</p>
                                    <p><hi rend="bold">Estimated dimensions | expressed as a range</hi></p>
                                    <p>The item cannot be measured precisely, but an estimated range can be recorded based on available evidence, such as digital images. The measurements are:</p>
                                    <p>Estimated | not taken directly from the item — Approximate | given as a lower and upper bound using <att>atLeast</att> and <att>atMost</att> — Applied to the entire item | not summarising variation, but expressing uncertainty for the full size</p>
                                    <table rend="rules">
                                      <row>
                                        <cell><p><hi rend="bold">• Extent:</hi> 254 leaves. Leaf height: 300-310 mm, width: 220-225 mm.</p>
                                          <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><extent>
<measure quantity="254" unit="leaf">254 leaves</measure>.
<dimensions type="leaf" unit="mm">
<height atLeast="300" atMost="310">300-310</height>
<width atLeast="220" atMost="225">220-225</width>
</dimensions>
</extent></egXML></p></cell>
                                        </row>
                                      </table>
                                      <p><hi rend="bold">Multiple size groups within the Item</hi></p>
                                      <p>The item contains two or more physically distinct groups of components, such as specific leaf ranges in a codex or batches of membranes or sheets, each with different dimensions. Record each size cohort separately by repeating <gi>dimensions</gi> within the same <gi>extent</gi>. Clarify the leaf ranges using <gi>note</gi> in element content. The measurements are:</p>
                                      <p>Grouped | recorded separately for each distinct set of leaves, membranes, or sheets — Precise | taken directly from the physical object, not estimated — Parallel | each set is described in its own <gi>dimensions</gi> block, within a shared <gi>extent</gi></p>
                                      <table rend="rules">
                                        <row>
                                          <cell><p><hi rend="bold">• Format:</hi> Codex</p>
                                            <p><hi rend="bold">• Material(s):</hi> Parchment</p>
                                            <p><hi rend="bold">• Extent:</hi> 156 leaves (ii+152 +ii). Leaf height: 450 mm, width: 325 mm. Leaf height: 242 mm, width: 210 mm. The leaves are in two sizes: leaves 5–6 differ from leaves 7–146.</p>
                                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><objectDesc form="codex">
<supportDesc material="parchment">
<support>
<material source="#aat" key="300011851">Parchment</material>
</support>
<extent>
<measure quantity="152" unit="leaf">156 leaves (ii+152 +ii)</measure>.
<dimensions type="leaf" unit="mm">
<height quantity="240">240</height>
<width quantity="205">205</width>
</dimensions>
<dimensions type="leaf" unit="mm">
<height quantity="242">242</height>
<width quantity="210">210</width>
</dimensions>
<note>The leaves are in two sizes: leaves 5–6 differ from leaves 7–146.</note>
</extent>
<!-- additional metadata -->
</supportDesc>
</objectDesc></egXML></p>
                                            <p rend="right"><hi rend="italic">Dersāna Mikā'ēl:</hi>  <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-ETHIOPIC-00011/15">Ethiopic MS 11</ref></p></cell>
                                        </row>
                                      </table>
                                      <p>A full stop followed by a space must be manually inserted immediately after the closing <gi>measure</gi> if it is followed by <gi>dimensions</gi>. The display of <gi>dimensions</gi>, whether used once or multiple times, is automatically formatted by the system. Capitalisation, such as Leaf height, and punctuation, such as the full stop after width followed by the measurement in millimetres (mm), are generated by the XSLT transformation.</p>
                                    </div>
                                    <div xml:id="foliation">
                                      <head><code>&lt;foliation&gt;</code> | foliation</head>
                                      <p rend="definition"><ref target="https://www.tei-c.org/release/doc/tei-p5-doc/en/html/ref-foliation.html"><gi>foliation</gi></ref> <hi rend="italic">(foliation) describes the numbering system or systems used to count the leaves or pages in a codex or similar object.</hi></p>
                                      <p rend="displayLabel">MDC display label — <hi rend="bold">Foliation</hi></p>
                                      <p><gi>foliation</gi> is used to record the foliation system of a manuscript or printed book, including the sequence of leaf numbers, the writing medium and placement of the numbers, and any information about when and by whom the numbering was added. It may also describe anomalies, errors, or the presence of multiple foliation systems.</p>
                                      <p>When the front and back of each leaf are assigned separate numbers, the item is considered paginated. In TEI P5, there is no pagination element. Instead, <gi>foliation</gi> is used to record both foliation and pagination. The numbering method should be clearly indicated in the prose within <gi>foliation</gi>.</p>
                                      <p><gi>foliation</gi> is repeatable<hi rend="bold">.</hi> It must contain at least one <gi>p</gi>. If multiple foliation or pagination systems are present, they may be recorded together in a single <gi>foliation</gi> using multiple <gi>p</gi>. However, best practice is to record each system separately, using multiple <gi>foliation</gi>, each with its own <gi>p</gi>.</p>
                                      <p>In legacy encoding practice, multiple foliation systems were sometimes distinguished using <att>xml:id</att>. Such usage may still be encountered in older files but is <hi rend="bold"><hi rend="italic">not</hi></hi> recommended for current practice. Instead, <gi>foliation</gi> should be encoded using <att>contemporary</att>.</p>
                                      <p rend="attHead"><code>@contemporary</code></p>
                                      <p><att>contemporary</att> (contemporary) specifies whether or not the foliation is contemporary with its contents.</p>
                                      <p>The following values should be used:</p>
                                      <p><val>true</val> the foliation is original, contemporary with its contents</p>
                                      <p><val>false</val> the foliation is not original, not contemporary with its contents</p>
                                      <p><val>unknown</val> the date of foliation is unknown</p>
                                      <p>In addition to <att>contemporary</att>, dating attributes may be used on <gi>foliation</gi> when the numbering can be dated with reasonable confidence. <att>notBefore</att> and <att>notAfter</att> may be used to express a date range, including approximate dates and periods such as centuries. Where only a single year is known, they may be assigned the same value. Where an exact date is known, <att>when</att> should be used.</p>
                                      <p>If the person responsible for the foliation is known, their name should be encoded using <code>&lt;name role="asn"&gt;&lt;persName/&gt;&lt;name&gt;</code>. If the personal name is listed in VIAF, include both <att>source</att> and <att>key</att> on <gi>name</gi> to reference the appropriate VIAF authority record. Where both display and standard forms are required, include two <gi>persName</gi> or <gi>orgName</gi> within <gi>name</gi>, one with <att>type</att>=<val>display</val> and one with <att>type</att>=<val>standard</val>. Otherwise, a single <gi>persName</gi> or <gi>orgName</gi> within <gi>name</gi> may be used.</p>
                                      <p>When the value <val>#viaf</val> is used for <att>source</att>, it indicates that the identifier recorded in <att>key</att> is drawn from this authority file. The prefix <code>#</code> indicates a reference to an identifier defined elsewhere in the same file. In this case, it refers to the <gi>taxonomy</gi> declared in the header with <att>xml:id</att>=<val>viaf</val>. This value can be selected from a controlled dropdown list when entering the attribute and does not need to be typed manually.</p>
                                      <p>Record the form of foliation or pagination, indicating whether the numbering system is in <hi rend="italic">Arabic numerals</hi> or <hi rend="italic">Roman numerals</hi>, both of which must always be capitalised.</p>
                                      <p>Record the placement of foliation or pagination using consistent terminology:</p>
                                      <p>upper right corner— upper left corner</p>
                                      <p>upper centre margin— lower centre margin</p>
                                      <p>lower right corner— lower left corner</p>
                                      <p>Indicate whether numbering appears on each recto, verso, or on both sides of each leaf. For Islamic and Hebrew manuscripts, specify whether it appears on side a, side b, or on both sides of each leaf.</p>
                                      <p>... Arabic numerals in the upper right corner of each recto.</p>
                                      <p>... Arabic numerals in the upper left corner of each side a.</p>
                                      <p>Specify the medium, ink, pencil, or other.</p>
                                      <p>Where relevant, note any later additions, corrections, errors, or irregularities in the numbering.</p>
                                      <p>If significant, note the absence of foliation or pagination.</p>
                                      <table rend="rules">
                                        <row>
                                          <cell><p rend="right">single <gi>foliation</gi> with multiple <gi>p</gi> | acceptable</p>
                                            <p><hi rend="bold">• Foliation:</hi></p>
                                            <p>Sixteenth-century ink foliation in Roman numerals, with i and xvi missing, and the sequence ending at lxxxxiiii.</p>
                                            <p>1–97: modern pencil foliation in Arabic numerals, in the upper right corner of each recto, added by the art historian Eric George Millar (1887–1966) in approximately 1925.</p>
                                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<foliation>
<p>Sixteenth-century ink foliation in Roman numerals, with i and xvi missing, and the sequence ending at lxxxxiiii.</p>
<p>1–97: modern pencil foliation in Arabic numerals, in the upper right corner of each recto, added by the art historian <name source="#viaf key="88705920"><persName type="display">Eric George Millar (1887–1966)</persName><persName type="standard">Millar, Eric George, 1887–1966</persName></name> in approximately 1925.</p>
</foliation>]]></egXML></p></cell>
                                          </row>
                                          <row>
                                            <cell><p rend="right">multiple <gi>foliation</gi>, with <att>contemporary</att> and date range | best practice</p>
                                              <p><hi rend="bold">• Foliation:</hi></p>
                                              <p>Sixteenth-century ink foliation in Roman numerals, with i and xvi missing, and the sequence ending at lxxxxiiii.</p>
                                              <p>1–97: modern pencil foliation in Arabic numerals, in the upper right corner of each recto, added by the art historian Eric George Millar (1887–1966) in approximately 1925.</p>
                                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<foliation contemporary="true" notBefore="1501" notAfter="1600">
<p>Sixteenth-century ink foliation in Roman numerals, with i and xvi missing, and the sequence ending at lxxxxiiii.</p>
</foliation>
<foliation contemporary="false" notBefore="1925" notAfter="1925">
<p>1–97: modern pencil foliation in Arabic numerals, in the upper right corner of each recto, added by the art historian <name source="#viaf key="88705920"><persName type="display">Eric George Millar (1887–1966)</persName><persName type="standard">Millar, Eric George, 1887–1966</persName></name> in approximately 1925.</p>
</foliation>]]></egXML></p></cell>
                                            </row>
                                            <row>
                                              <cell><p rend="right">Colonna Missal II<hi rend="bold">:</hi> <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-LATIN-00032-A/1">Latin MS 32A</ref></p></cell>
                                            </row>
                                            <row>
                                              <cell><p rend="right">single <gi>foliation</gi> | unknown date</p>
                                                <p><hi rend="bold">• Foliation:</hi></p>
                                                <p>Pencil foliation in Arabic numerals, the upper right corner of each recto.</p>
                                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<foliation contemporary="unknown">
<p>Pencil foliation in Arabic numerals, in the upper right corner of each recto.<p>
</foliation>]]></egXML></p></cell>
                                              </row>
                                              <row>
                                                <cell><p rend="right">page numbering | pagination</p>
                                                  <p><hi rend="bold">• Foliation:</hi></p>
                                                  <p>1–480: nineteenth-century pencil pagination in Arabic numerals, in the upper right corner of each leaf.</p>
                                                  <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><foliation contemporary="false" notBefore="1801" notAfter="1900">
<p>1–480: nineteenth-century pencil pagination in Arabic numerals, in the upper right corner of each leaf.</p>
</foliation></egXML></p></cell>
                                                </row>
                                              </table>
                                            </div>
                                            <div xml:id="collation">
                                              <head><code>&lt;collation&gt;</code> | collation</head>
                                              <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-collation.html"><gi>collation</gi></ref> <hi rend="italic">(collation) contains a description of how the leaves, bifolia, or similar objects are physically arranged.</hi></p>
                                              <p rend="displayLabel">MDC display label — <hi rend="bold">Collation</hi></p>
                                              <p><gi>collation</gi> is used to describe the physical structure and arrangement of quires (or gatherings) within a codex, whether manuscript or printed. It records the composition and sequence of these gatherings, providing evidence of the item’s production and any subsequent alteration, such as the addition or loss of leaves or the insertion of new material.</p>
                                              <p><gi>collation</gi> may include one or more of the following child elements, in this order: <gi>formula</gi>, <gi>signatures</gi>, <gi>catchwords</gi>, <gi>secFol</gi>.</p>
                                              <p><gi>collation</gi> may begin with one or more <gi>p</gi> describing the overall structure of the codex, such as the total number of quires and their predominant composition, and noting any irregularities or uncertainties, for example, missing, replaced, or conjoined leaves. The arrangement of the quires may then be encoded either as a concise collation formula using <gi>formula</gi>, or more usually as <gi>list</gi> detailing the endleaves and quires in sequence.</p>
                                              <p><gi>formula</gi> and <gi>list</gi> both record the structure of quires within <gi>collation</gi>, but they differ in purpose and level of detail.</p>
                                              <p><gi>formula</gi> provides a concise summary of the quire structure, often expressed in conventional bibliographical notation, for example, <hi rend="italic">A–C⁸ D⁴.</hi> It is most appropriate when reproducing collation information from earlier catalogue descriptions, when recording printed book collations in traditional form, or when a brief overview is sufficient.</p>
                                              <p><gi>list</gi>, by contrast, allows a detailed and structured description of each quire, including endleaves, irregularities, and physical features, and is therefore preferred in most cases.</p>
                                              <p>Although both elements may appear within <gi>collation</gi>, they normally should <hi rend="bold"><hi rend="italic">not</hi></hi> be used together.</p>
                                              <p>Within <gi>collation</gi>, each <gi>item</gi> within <gi>list</gi> records a single quire or component of the physical structure. Endleaves are recorded at the beginning and end of the list but are not assigned a quire formula. Each quire entry should include the quire number, the number of leaves expressed as a superscript using <code>&lt;hi</code> <code>rend="superscript"&gt;</code>, and, if known, the leaf range in brackets.</p>
                                              <p><hi rend="bold">Regular quires</hi></p>
                                              <p>Complete quires composed of regular bifolia, meaning gatherings that retain their original structure and full complement of leaves without insertions, losses, or irregularities, should be recorded in <gi>collation</gi> as individual quire entries.</p>
                                              <table rend="rules">
                                                <row>
                                                  <cell><p><hi rend="bold">• Collation:</hi></p>
                                                    <p>2 modern paper endleaves</p>
                                                    <p>1 original parchment endleaf</p>
                                                    <p>Quire 16 (1–6)</p>
                                                    <p>Quire 28 (7–14)</p>
                                                    <p>Quire 310 (15–24)</p>
                                                    <p>Quire 412 (25–36)</p>
                                                    <p>2 modern paper endleaves</p>
                                                    <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><collation>
<list>
<item>2 modern paper endleaves</item>
<item>1 original parchment endleaf</item>
<item>Quire 1 <hi rend="superscript">6</hi> (1–6)</item>
<item>Quire 2 <hi rend="superscript">8</hi> (7–14)</item>
<item>Quire 3 <hi rend="superscript">10</hi> (15–24)</item>
<item>Quire 4 <hi rend="superscript">12</hi> (25–36)</item>
<item>2 modern paper endleaves</item>
</list>
<!-- additional metadata -->
</collation></egXML></p></cell>
                                                  </row>
                                                </table>
                                                <p>Leaf ranges are expressed using bare numerals, for example, 1–8, to show the sequence of leaves within a quire. This is the standard and sufficient way of describing the extent of a quire in <gi>collation</gi>, referring implicitly to eight leaves, each with recto and verso sides. Because <gi>collation</gi> records the physical structure of the volume rather than the text’s position on each side, recto and verso indicators (r | v) are normally unnecessary. They should be added only when reference to a particular side is structurally significant, such as when noting a missing half-leaf or an inserted singleton.</p>
                                                <p>Within <gi>item</gi>, the use of <gi>locus</gi> with <att>from</att> and <att>to</att> is optional and it is not required for structural descriptions of quires. Leaf ranges given in brackets, for example (1–8), are sufficient and standard practice.</p>
                                                <p><hi rend="bold">Adjoining quires</hi></p>
                                                <p>When several adjoining quires share the same regular structure, they may be described together in a single entry. For example, the entry <code>&lt;item&gt;Quires 1–4&lt;hi rend="superscript"&gt;12&lt;/hi&gt;</code> (2–49)<gi>item</gi> indicates that quires 1 to 4 each consist of 12 leaves, covering leaves 2–49.</p>
                                                <table rend="rules">
                                                  <row>
                                                    <cell><p><hi rend="bold">• Collation:</hi></p>
                                                      <p>1 original endleaf</p>
                                                      <p>Quire 1-412 (2–49)</p>
                                                      <p>1 original endleaf</p>
                                                      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><collation>
<list>
<item>1 original endleaf</item>
<item>Quires 1-4 <hi rend="superscript">12</hi> (2–49)</item>
<item>1 original endleaf</item>
</list>
<!-- additional metadata -->
</collation></egXML></p></cell>
                                                    </row>
                                                  </table>
                                                  <p><hi rend="bold">Irregular quires</hi></p>
                                                  <p>When the manuscript structure is irregular, or where leaves have been inserted, lost, or conjoined, begin <gi>collation</gi> with one or more <gi>p</gi> that summarise these conditions before listing individual gatherings. The following terminology should be used consistently when describing the physical structure.</p>
                                                  <p><hi rend="bold">Not present</hi> when a leaf has been removed or lost, without affecting the contents of the volume, but for reasons that cannot presently be established.</p>
                                                  <p><hi rend="bold">Excised</hi> when a leaf has clearly been cut out deliberately (especially if blank).</p>
                                                  <p><hi rend="bold">Missing</hi> when a leaf has been lost, perhaps but not necessarily accidentally, causing the text or decorative scheme to become imperfect.</p>
                                                  <p><hi rend="bold">Cancelled</hi> when a leaf has been removed but there is no evident interruption to the text or decorative scheme (e.g. leaf with an error, removed during copying).</p>
                                                  <p><hi rend="bold">Inserted</hi> when an extra leaf is contemporary with the production of the manuscript (e.g. a miniature on a single leaf in a Book of Hours)</p>
                                                  <p><hi rend="bold">Added</hi> when an extra leaf is a later insertion.</p>
                                                  <p>The symbols + and − can be used to indicate added or missing leaves: <code>&lt;hi rend="superscript"&gt;12+1&lt;/hi&gt;</code> or <code>&lt;hi</code> <code>rend="superscript"&gt;12-2&lt;/hi&gt;</code>. When the total cannot be expressed numerically, it may be written in words, for example <code>&lt;hi</code> <code>rend="superscript"&gt;eleven&lt;/hi&gt;</code>. Explanations of irregularities should precede the leaf range, leaving the brackets to contain only the range itself.</p>
                                                  <table rend="rules">
                                                    <row>
                                                      <cell><p><hi rend="bold">• Collation:</hi></p>
                                                        <p>The manuscript consists of 11 irregular quires. Some bifolia may have been formed from originally separate single sheets that were joined together. Some leaves may have been inserted as singletons, and some noted below as ‘removed’ may never in fact have formed part of the original volume.</p>
                                                        <p>2 modern paper endleaves</p>
                                                        <p>1 original parchment endleaf</p>
                                                        <p>Quires 112-1+1 first leaf missing before leaf 1, replaced in the 17th century to supply missing text (1–12)</p>
                                                        <p>Quire 2-412 (13–48)</p>
                                                        <p>Quire 512+1 third leaf inserted after leaf 51 (49–61)</p>
                                                        <p>Quire 612 fourth leaf after leaf 64 and ninth leaf after leaf 69 are conjoined singletons (62–73)</p>
                                                        <p>Quire 7eleven (74–84)</p>
                                                        <p>Quire 812-2 eleventh and twelfth leaves after leaf 94 excised, probably blank (85–94)</p>
                                                        <p>1 original parchment endleaf</p>
                                                        <p>2 modern paper endleaves</p>
                                                        <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><collation>
<p>The manuscript consists of 11 irregular quires. Some bifolia may have been formed from originally separate single sheets that were joined together. Some leaves may have been inserted as singletons, and some noted below as ‘removed’ may never in fact have formed part of the original volume.</p>
<list>
<item>2 modern paper endleaves</item>
<item>1 original parchment endleaf</item>
<item>Quires 1<hi rend="superscript">12-1+1</hi> first leaf missing before leaf 1, replaced in the 17th century to supply missing text (1–12)</item>
<item>Quire 2-4<hi rend="superscript">12</hi> (13–48)</item>
<item>Quire 5 <hi rend="superscript">12+1</hi> third leaf inserted after leaf 51 (49–61)</item>
<item>Quire 6 <hi rend="superscript">12</hi> fourth leaf after leaf 64 and ninth leaf after leaf 69 are conjoined singletons (62–73)</item>
<item>Quire 7<hi rend="superscript">eleven</hi> (74–84)</item>
<item>Quire 8<hi rend="superscript">12-2</hi> eleventh and twelfth leaves after leaf 94 excised, probably blank (85–94)</item>
<item>1 original parchment endleaf</item>
<item>2 modern paper endleaves</item>
</list>
<!-- additional metadata -->
</collation></egXML></p></cell>
                                                      </row>
                                                    </table>
                                                    <p>For multi-part, composite manuscripts, the collation of each part should be recorded at the level of <gi>msPart</gi>. It may also be recorded at the level of the manuscript as a whole, if this aids clarity. In retroconversion this is likely to involve reorganisation of the formula.</p>
                                                    <p><gi>list</gi> should <hi rend="bold"><hi rend="italic">not</hi></hi> be nested within a <gi>p</gi> within <gi>collation</gi>.</p>
                                                    <p>Do <hi rend="bold"><hi rend="italic">not</hi></hi> include a full stop at the end of each <gi>item</gi> within <gi>list</gi>.</p>
                                                    <p><hi rend="bold"><hi rend="italic">Avoid</hi></hi> legacy or informal expressions such as wants, wanting, lacks, lacking, gone, (gone), cut out, or replaced. Use the preferred terms defined above (excised, missing, cancelled, inserted, added).</p>
                                                    <div xml:id="endleaves-free-endleaves-pastedowns">
                                                      <head>endleaves | free endleaves | pastedowns</head>
                                                      <p>Within <gi>collation</gi>, use endleaf or endleaves as the general, neutral term for any leaves located before or after the main textblock. This term applies to both manuscripts and printed books and includes all leaves that form the physical or structural connection between the textblock and the binding. Where greater precision is required, the following distinctions may be made:</p>
                                                      <p><hi rend="bold">free endleaves</hi> are the endleaves not adhered to the inner surface of the board or cover. These may be the conjugate of a pastedown or may consist of one or more unattached leaves positioned between the pastedown and the main textblock. The term flyleaf is not used due to its imprecise and inconsistent application across descriptive traditions.</p>
                                                      <p><hi rend="bold">Pastedowns</hi> are the endleaves adhered to the inner surface of the covers or boards, anchoring the textblock within the binding. As structural components of the binding, pastedowns are normally described in <gi>binding</gi>, but may be referenced in <gi>collation</gi> if they are relevant to the quire sequence or clarify the arrangement of endleaves.</p>
                                                      <p>The term endpaper is <hi rend="bold"><hi rend="italic">not</hi></hi> used. Although it is common in bibliographical descriptions of printed books, it is imprecise in structural terms and conflates pastedowns and free endleaves. For clarity and consistency, use endleaves as the general term, with free endleaves and pastedowns used where greater precision is required.</p>
                                                      <p>Endleaves should be included in <gi>collation</gi>, with descriptive entries placed at the beginning and end to represent those at the front and rear of the volume. Original and later endleaves should be clearly distinguished and recorded descriptively, for example, <hi rend="italic">2 modern endleaves</hi>,  rather than incorporated into the main collation formula.</p>
                                                    </div>
                                                    <div xml:id="original-modern-endleaves">
                                                      <head>original | modern endleaves</head>
                                                      <p>Use original and modern to record endleaves according to their relationship to the manuscript’s physical structure.</p>
                                                      <p><hi rend="bold">original</hi> for endleaves that were produced with, or are integral to, the manuscript’s first binding or original structure.</p>
                                                      <p><hi rend="bold">modern</hi> for endleaves added in any subsequent binding, repair, or restoration, regardless of date.</p>
                                                      <p><hi rend="bold"><hi rend="italic">Avoid</hi></hi> using medieval, as it denotes a historical period rather than a structural relationship. Its use can introduce ambiguity, since additions from a medieval rebinding are not necessarily original. Use <hi rend="italic">original</hi> for endleaves integral to the first binding, and <hi rend="italic">modern</hi> for anything added later.</p>
                                                    </div>
                                                    <div xml:id="leaf-vs-folio">
                                                      <head>leaf vs folio</head>
                                                      <p>Always use leaf as the descriptive term for the physical structure of manuscripts and early printed books, never f., ff. or folio, fol. or folios, fols. The <gi>collation</gi> records how the volume is constructed, not the text’s position on each side of a leaf, so sides (r | v) are normally irrelevant.</p>
                                                      <p>Use bare numerals to express leaf ranges and quire extents, for example, 49–61. This is the standard and sufficient way to indicate the sequence of leaves within a quire. Include r | v indicators only when reference to a specific side is structurally significant. For example, when noting an inserted or missing half-leaf.</p>
                                                      <p>Use numerals (1, 2, 3 ...) for quantitative and structural information, and spelled-out ordinals (first, second, third), for sequential references within prose, for example, the first leaf is missing before leaf 1 | The manuscript consists of 11 irregular quires.</p>
                                                      <p>Following the structural formula, <gi>collation</gi> may include details of quire and leaf <gi>signatures</gi>, <code>&lt;catchwords</code>&gt;, and <gi>secFol</gi>, where present. These features, which complement the gathering formula, provide further evidence of the item’s physical structure, forming the concluding part of the collation description.</p>
                                                      <p>Each of these elements is governed by a specific content model. <gi>signatures</gi> belongs to the <code>macro.specialPara</code> model class, which means it can contain either straightforward inline text or, when more structure is required, one or more <gi>p</gi>. In contrast, both <gi>catchwords</gi> and <gi>secFol</gi> are defined by the more restrictive <code>macro.phraseSeq</code> class. As such, they are limited to phrase-level content and must <hi rend="bold"><hi rend="italic">not</hi></hi> include any block-level elements like <gi>p</gi> within them.</p>
                                                    </div>
                                                  </div>
                                                  <div xml:id="signatures">
                                                    <head><code>&lt;signatures&gt;</code> | signatures</head>
                                                    <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-signatures.html"><gi>signatures</gi></ref> <hi rend="italic">(signatures) contains discussion of the leaf or quire signatures found within a codex or similar object.</hi></p>
                                                    <p><gi>signatures</gi> is a phrase-level element that, within <gi>collation</gi>, records information about quire or leaf signatures in a manuscript or printed book. It may contain a concise formula, an explanatory note, or a combination of both. It is used to describe signature systems, whether alphabetic, alphanumeric, or based on an ad hoc system, together with their sequence, placement, irregularities, interruptions, or later modifications.</p>
                                                    <p><gi>signatures</gi> can be used for leaf signatures alone or for a combination of quire and leaf signatures. The optional <att>type</att> may be used where the distinction needs to be made explicit.</p>
                                                    <p rend="attHead"><code>@type</code></p>
                                                    <p><att>type</att> distinguishes between leaf and quire signatures</p>
                                                    <p>The following values should be used:</p>
                                                    <p><val>leaf</val> for leaf or bifolium signatures, usually found in the lower right corner of the recto side of leaves in the first half of a quire, and usually following an alphanumerical sequence.</p>
                                                    <p><val>quire</val> for quire signatures or numbers, usually found on the verso of the last leaf of the quire, or sometimes on the recto of the first leaf, and used to indicate the sequence of quires.</p>
                                                    <p> This is a customisation and not currently part of the TEI standard.</p>
                                                    <p>Because <gi>signatures</gi> is governed by the <code>macro.specialPara</code> content model, it may contain either paragraph-level or phrase-level content. It is typically treated as block-level and may contain multiple <gi>p</gi>. Each <gi>p</gi> should be a distinct descriptive note. Use a separate <gi>p</gi> for any additional information, so that distinct descriptive details remain clearly separated.</p>
                                                    <p>In legacy encoding practice, <gi>signatures</gi> was sometimes enclosed within a <gi>p</gi> or a <gi>p</gi> was placed within <gi>signatures</gi> contained inside <gi>collation</gi>, to separate it from the structural formula and other descriptive content or elements, ensuring consistent paragraph spacing and display. Such usage may still be encountered in older files but is <hi rend="bold"><hi rend="italic">not</hi></hi> recommended in current practice. <hi rend="bold"><hi rend="italic">Neither</hi></hi> <code>&lt;signatures&gt;&lt;p/&gt;&lt;/signatures&gt;</code> <hi rend="bold"><hi rend="italic">nor</hi></hi> <code>&lt;p&gt;&lt;signatures/&gt;&lt;/p&gt;</code> should be used. <gi>signatures</gi> should occur directly within <gi>collation</gi>, and paragraph spacing and display are generated by the XSLT transformation.</p>
                                                    <p>The <gi>signatures</gi> content should convey the physical characteristics of these marks, noting how they are expressed, where they are positioned, and any evidence of later intervention.</p>
                                                    <p>If the name of the individual or organisation responsible for the quire or leaf signatures is known, it should be encoded using <gi>name</gi>, containing either <gi>persName</gi> or <gi>orgName</gi> as appropriate. If the name is listed in VIAF, include both <att>source</att> and <att>key</att> on <gi>name</gi> to reference the appropriate VIAF authority record. Where both display and standard forms are required, include two <gi>persName</gi> or <gi>orgName</gi> within <gi>name</gi>, one with <att>type</att>=<val>display</val> and one with <att>type</att>=<val>standard</val>. Otherwise, a single <gi>persName</gi> or <gi>orgName</gi> within <gi>name</gi> may be used.</p>
                                                    <p>The following outlines the preferred form, terminology, and stylistic conventions for recording this information in a clear and consistent manner:</p>
                                                    <p>Record the form of the signatures (<hi rend="italic">alphabetic</hi>, <hi rend="italic">alphanumeri</hi>c, or some ad hoc system), noting whether numerals are <hi rend="italic">Arabic</hi> or <hi rend="italic">Roman</hi>, or used in combination with letters.</p>
                                                    <p>Record the placement of the signature marks using consistent terminology:</p>
                                                    <p>lower inner margin — lower centre margin — lower outer margin (most common)</p>
                                                    <p>Specify the medium used, such as ink, pencil.</p>
                                                    <p>Where relevant, note any later additions, corrections, errors, or irregularities in the numbering.</p>
                                                    <p>If significant, note the absence of signatures.</p>
                                                    <table rend="rules">
                                                      <row>
                                                        <cell><p rend="right">leaf | quire signatures</p>
                                                          <p><hi rend="bold">• Collation:</hi></p>
                                                          <p>—</p>
                                                          <p>Leaf signatures in typical alphanumeric form ai–aiiii to mi–miiii, written in pencil in the lower right corner of rectos in the first half of each quire, in the ninth-century part of the manuscript only, by Henry Bradshaw (1831–1886), University Librarian 1867-1886.</p>
                                                          <p>Quire signatures in Arabic numerals (1–20), written in ink by an eighteenth- or nineteenth-century hand in the centre of the bottom margin of the recto of the first leaf of each quire, extending across the later medieval additions and the ninth-century core.</p>
                                                          <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<collation>
<!-- additional metadata -->
<signatures type="leaf">Leaf signatures in typical alphanumeric form ai–aiiii to mi–miiii, written in pencil in the lower right corner of rectos in the first half of each quire, in the ninth-century part of the manuscript only, by <name source="#viaf key="37074791"><persName type="display">Henry Bradshaw (1831–1886)</persName><persName type="display">Bradshaw, Henry, 1831–1886</persName></name>, University Librarian 1867-1886.</signatures>
<signatures type="quire">Quire signatures in Arabic numerals (1–20), written in ink by an eighteenth- or nineteenth-century hand in the lower centre margin of the recto of the first leaf of each quire, extending across the later medieval additions and the ninth-century core.</signatures
<!-- additional metadata -->
</collation>]]></egXML></p></cell>
                                                        </row>
                                                      </table>
                                                      <p>Write centuries in words and lowercase, such as eighteenth century, rather than using numeric forms such as 18th century or 18th-century. Insert a hyphen when the term is used adjectivally, for example, eighteenth-century hand, and when expressing an uncertain or alternative range, connect the terms with a hyphen (-) and or, for instance, eighteenth- or nineteenth-century hand.</p>
                                                      <p>For early printed books, <gi>collation</gi> may include both a collation formula, which describes the sequence and extent of gatherings, for example, a–z⁸ A–F⁸ G¹², and a description of printed signature marks, the marks actually printed on certain leaves, typically at the foot of the first few rectos of each gathering, such as a, aii, aiii, aiiii.</p>
                                                      <p>For further information on collation formulas, see: STCV. Bibliography of the Hand Press Book: <ref target="https://manual.stcv.be/p/Collation_Formula">Collation Formula</ref></p>
                                                      <p>During MARC-to-TEI conversion, content from MARC field 500 (General Note) or 591 (Local Note) that begins with the string <hi rend="italic">Signatures:</hi> usually represents a collation formula, even though it is “labelled” as signatures. In TEI, this information should be encoded using <gi>formula</gi>, while any supplementary notes concerning signature marks, such as mis-signed leaves, omissions, or irregularities, should be recorded within <gi>signatures</gi>. Other physical notes, such as blank or leaves, should be described in a separate <gi>p</gi> within <gi>collation</gi>.</p>
                                                      <table rend="rules">
                                                        <row>
                                                          <cell><p rend="right"><gi>formula</gi> | MARC signatures</p>
                                                            <p><hi rend="bold">• Collation:</hi> pi2 a-z8 A-H8</p>
                                                            <p>Leaf b2 is mis-signed a2.</p>
                                                            <p>Leaf l2 (82) is blank except for foliation and signature; leaf H7 (penultimate leaf) is blank.</p>
                                                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><collation>
<formula>pi<hi rend="superscript">2</hi> a–z<hi rend="superscript">8</hi> A-H<hi rend="superscript">8</hi></formula>
<signatures>Leaf b2 is mis-signed a2.</signatures>
<p>Leaf l2 (82) is blank except for foliation and signature; leaf H7 (penultimate leaf) is blank.</p>
</collation></egXML></p>
                                                            <p rend="right">Dante col sito, et forma dell'inferno tratta dalla istessa descrittione del poeta: <ref target="https://www.digitalcollections.manchester.ac.uk/view/PR-ALDI-05541/1">5541</ref></p></cell>
                                                        </row>
                                                      </table>
                                                      <p>Use <hi rend="italic">folio</hi> when a single numbered side is blank, for example, <hi rend="italic">folio 20v</hi> is blank. Use <hi rend="italic">leaf</hi> when both sides of a single leaf are blank, for example, <hi rend="italic">leaf 20</hi> is blank.</p>
                                                    </div>
                                                    <div xml:id="catchwords">
                                                      <head><code>&lt;catchwords&gt;</code> | catchwords</head>
                                                      <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-catchwords.html"><gi>catchwords</gi></ref> <hi rend="italic">(catchwords) describes the system used to ensure correct ordering of the quires or similar making up a codex, incunable, or other object typically by means of annotations at the foot of the page.</hi></p>
                                                      <p><gi>catchwords</gi> is a phrase-level element that, within <gi>collation</gi>, records the presence and placement of catchwords and describes their distribution across the gatherings of a codex.</p>
                                                      <p>Catchwords typically appear in the lower margin of the final verso of each quire and may occur regularly or intermittently throughout the collation. They are usually plain but are sometimes enclosed within decorative frames, features that help distinguish them from the main text.</p>
                                                      <p>In legacy encoding practice, <gi>catchwords</gi> was sometimes enclosed within a <gi>p</gi> inside <gi>collation</gi> to separate it from the structural formula and other descriptive content or elements, ensuring consistent paragraph spacing and display. Such usage may still be encountered in legacy files but is <hi rend="bold"><hi rend="italic">not</hi></hi> recommended in current practice. Instead, <gi>catchwords</gi> should appear directly within <gi>collation</gi>. Paragraph breaks for display are generated by the XSLT transformation.</p>
                                                      <p>The <gi>catchwords</gi> content should convey the physical characteristics of these marks, noting how they are expressed, where they are positioned, and any evidence of later intervention. The following outlines the preferred form, terminology, and stylistic conventions for recording this information in a clear and consistent manner.</p>
                                                      <p>Record the orientation and placement of catchwords using consistent terminology:</p>
                                                      <p>horizontal — vertical — diagonal</p>
                                                      <p>lower inner margin — lower centre margin— lower outer margin</p>
                                                      <p>Specify the medium used, such as ink, pencil.</p>
                                                      <p>If the catchwords are enclosed within a decorative frame or ruled box, record this.</p>
                                                      <p>Specify orientation and location on the leaf, using <gi>locus</gi> with <att>from</att> and <att>to</att> where visible.</p>
                                                      <p>Where relevant, specify the scribe or hand, and include references to any later additions or changes.</p>
                                                      <p>If significant, note the absence of catchwords.</p>
                                                      <table rend="rules">
                                                        <row>
                                                          <cell><p><hi rend="bold">• Collation:</hi></p>
                                                            <p>Horizontal catchwords in the lower centre margin of the verso of the last leaf of each quire: 10v, 18v, …172v.</p>
                                                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><collation>
<catchwords>Horizontal catchwords in the lower centre margin of the verso of the last leaf of each quire: <locus from="10v" to="10v">10v</locus>, <locus from="18v" to="18v">18v</locus>, <locus from="26v" to="26v">26v</locus>, … <locus from="172v" to="172v">172v</locus>. </catchwords>
</collation></egXML></p>
                                                            <p rend="right"><hi rend="italic">Il Canzoniere di Petrarca e Le Rime di Dante*</hi><hi rend="italic">:*</hi> <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-ITALIAN-00001/1">Italian MS 1</ref></p>
                                                            <list rend="bulleted">
                                                              <item><hi rend="italic">In this example, the use of an ellipsis (…) indicates that intermediate instances have been omitted for brevity. In total, 21 catchwords are recorded.</hi></item>
                                                            </list></cell>
                                                        </row>
                                                      </table>
                                                    </div>
                                                    <div xml:id="secFol">
                                                      <head><code>&lt;secFol&gt;</code> | second folio</head>
                                                      <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-secFol.html"><gi>secFol</gi></ref> <hi rend="italic">(second folio) marks the word or words taken from a fixed point in a codex (typically the beginning of the second leaf) in order to provide a unique identifier for it.</hi></p>
                                                      <p><gi>secFol</gi> is a phrase-level element, used to record the <hi rend="italic">secundo folio</hi>, also known as <hi rend="italic">dictio probatoria</hi>, consisting of the first two or three words on the second leaf of a codex. Medieval and Renaissance libraries widely used the <hi rend="italic">secundo folio</hi> to distinguish individual copies with identical incipits.</p>
                                                      <p>In legacy encoding practice, <gi>secFol</gi> was sometimes enclosed within a <gi>p</gi> contained inside <gi>collation</gi> to separate it from the structural formula and other descriptive content, ensuring consistent paragraph spacing and display. In other cases, <gi>secFol</gi> appeared within a <gi>p</gi> directly after <gi>physDesc</gi>. Such usage may still be encountered in legacy files but is <hi rend="bold"><hi rend="italic">not</hi></hi> recommended in current practice. Instead, <gi>secFol</gi> should be encoded directly within <gi>collation</gi>. Paragraph breaks for display are generated by the XSLT transformation.</p>
                                                      <p><gi>secFol</gi> is typically placed after <gi>signatures</gi> and <gi>catchwords</gi> within <gi>collation</gi>. Each entry inside a <gi>secFol</gi> should follow this format:</p>
                                                      <p><code>Secundo folio: transcription</code></p>
                                                      <p>The phrase <hi rend="italic">Secundo folio</hi> should appear at the beginning, followed by a location reference (folio | page number) using <gi>locus</gi> with <att>from</att> and <att>to</att>, then a colon (:), and finally a transcription of the opening words from the second leaf. The transcription should be given exactly as it appears in the source, preserving original spelling, punctuation, and letterforms, and should be encoded using <code>&lt;hi</code> <code>rend="italic"&gt;</code>.</p>
                                                      <table rend="rules">
                                                        <row>
                                                          <cell><p><hi rend="bold">• Collation:</hi></p>
                                                            <p>—</p>
                                                            <p>Secundo folio on10v: <hi rend="italic">To bathe</hi>.</p>
                                                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><collation>
<!-- additional metadata -->
<secFol>Secundo folio on <locus from="1r" to="1r" >1r</locus>: <hi rend="italic">To bathe </hi>.</secFol>
<!-- additional metadata -->
</collation></egXML></p>
                                                            <p rend="right"><hi rend="italic">Siege of Troy</hi>: <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-ENGLISH-00001/1">English MS 1</ref></p></cell>
                                                        </row>
                                                      </table>
                                                    </div>
                                                    <div xml:id="condition">
                                                      <head><code>&lt;condition&gt;</code> | condition</head>
                                                      <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-condition.html"><gi>condition</gi></ref> <hi rend="italic">(condition) contains a description of the physical condition of the manuscript or object.</hi></p>
                                                      <p rend="displayLabel">MDC display label — <hi rend="bold">Condition</hi></p>
                                                      <p><gi>condition</gi> is a context-dependent element, and may be used within an appropriate structural container, such as <gi>supportDesc</gi> for leaves, <gi>bindingDesc</gi> for bindings, or <gi>sealDesc</gi> for seals. It should <hi rend="bold"><hi rend="italic">not</hi></hi> be used to describe conservation activity, which belongs in <gi>custodialHist</gi>.</p>
                                                      <p>In the context of <gi>supportDesc</gi>, <gi>condition</gi> is used to provide a brief description of the state of the physical support. This includes any physical alteration or damage, whether intentional or unintentional, affecting the legibility of the text or the clarity of the decoration. This may include detached, loose, torn, mutilated, or otherwise damaged leaves, flaking ink or pigments, ink corrosion or bleed-through, deliberate damage to decorative elements, and retouching of the text or decoration. It is <hi rend="bold"><hi rend="italic">not</hi></hi> necessary to repeat information about excised, missing or cancelled leaves or gatherings, as these are more appropriately recorded in <gi>collation</gi>.</p>
                                                      <p>While <gi>condition</gi> remains a lightweight, unstructured element intended for concise description of physical condition, its content must always be enclosed in one or more <gi>p</gi>, depending on the level of detail required.</p>
                                                      <table rend="rules">
                                                        <row>
                                                          <cell><p><hi rend="bold">• Condition:</hi></p>
                                                            <p>The manuscript is incomplete and damaged, with several leaves excised and removed at various points, leading to the loss of both text and illuminations. Additionally, intentional damage is evident in several areas where the manuscript has been defaced, likely due to the nature of its content.</p>
                                                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><condition>
<p>The manuscript is incomplete and damaged, with several leaves excised and removed at various points, leading to the loss of both text and illuminations. Additionally, intentional damage is evident in several areas where the manuscript has been defaced, likely due to the nature of its content.</p>
</condition></egXML></p>
                                                            <p rend="right"><hi rend="italic">Psalter of Joan of Navarre</hi>: <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-LATIN-00022/1">Latin MS 22</ref></p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p><hi rend="bold">• Condition:</hi></p>
                                                            <p>The legibility of the text is affected in parts due to ink stains (blots and smudges).</p>
                                                            <p>The text on the inner margin is partially obscured by the binding.</p>
                                                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><condition>
<p>The legibility of the text is affected in parts due to ink stains (blots and smudges).</p>
<p>The text on the inner margin is partially obscured by the binding.</p>
</condition></egXML></p>
                                                            <p rend="right"><hi rend="italic">Letter to Heinrich Simon from his sisters Hermine, Auguste, and Julie Simon</hi>: <ref target="https://www.digitalcollections.manchester.ac.uk/view/AR-SIM-00001-00194/1">SIM/1/194</ref></p></cell>
                                                        </row>
                                                      </table>
                                                      <p><hi rend="bold">General remarks: condition</hi></p>
                                                      <p><gi>condition</gi> should be used only where a significant or clearly observable condition issue is present. Items in good or stable condition do <hi rend="bold"><hi rend="italic">not</hi></hi> require an explicit statement.</p>
                                                      <p>Damage affecting the binding, such as weak joints, detached boards, loose headbands or other structural defects, should be recorded within <gi>bindingDesc</gi>.</p>
                                                      <p>Damage affecting a seal, such as chips, cracks, detachment or surface wear, should be recorded within <gi>sealDesc</gi>.</p>
                                                      <p><gi>condition</gi> may also be used to describe changes or repairs. However, where a documented conservation intervention exists, detailing when, by whom and what was done, this information should more appropriately be recorded as part of the custodial history within <gi>custodialHist</gi>.</p>
                                                    </div>
                                                    <div xml:id="layoutDesc">
                                                      <head><code>&lt;layoutDesc&gt;</code> | layout description</head>
                                                      <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-layoutDesc.html"><gi>layoutDesc</gi></ref> <hi rend="italic">(layout description) collects the set of layout descriptions applicable to a manuscript or other object.</hi></p>
                                                      <p rend="displayLabel">MDC display label — <hi rend="bold">Layout</hi></p>
                                                      <p><gi>layoutDesc</gi> is used to describe both the layout and the physical preparation of the written surface, that is, how text is arranged on the leaves and how the leaves were physically prepared. This includes, for example, the number of written, ruled, or pricked lines and columns, the size of margins, and the presence of distinct textual blocks such as glosses, commentaries, or diagrams.</p>
                                                      <p>One or more different layouts may be identified within a single codex. Each should be described using a separate <gi>layout</gi>, which may contain one or more <gi>p</gi> describing the layout in detail.</p>
                                                      <p>In addition, attributes on <gi>layout</gi> can be used to provide structured information, such as the number of columns or written lines, writing orientation, or ruling method.</p>
                                                    </div>
                                                    <div xml:id="layout">
                                                      <head><code>&lt;layout&gt;</code> | layout</head>
                                                      <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-layout.html"><gi>layout</gi></ref> <hi rend="italic">(layout) describes how text is laid out on the page or surface of the object, including information about any ruling, pricking, or other evidence of page-preparation techniques.</hi></p>
                                                      <p><gi>layout</gi> within <gi>layoutDesc</gi> is used to provide structured information about the layout of the written surface. Where the layout is sufficiently regular, the element’s attributes may be adequate on their own. However, a prose description should also be included to provide a fuller context.</p>
                                                      <p>Since <gi>layout</gi> is repeatable, multiple distinct layouts may be described within a single <gi>layoutDesc</gi>, using a combination of attributes and prose description, particularly where the arrangement of text varies significantly across the item.</p>
                                                      <p><gi>layout</gi> includes <att>columns</att>, <att>writtenLines</att>, and <att>ruledLines</att>, which provide quantitative information about the number of columns and the number of written and ruled lines.</p>
                                                      <p rend="attHead"><code>@columns | @ruledLines | @writtenLines</code></p>
                                                      <p>Each attribute accepts one or two values of type <ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-teidata.count.html"><code>teidata.count</code></ref><code>,</code> separated by space:</p>
                                                      <p><att>columns</att> (columns) specifies the number of columns per page</p>
                                                      <p><att>ruledLines</att> (ruled lines) specifies the number of ruled lines per column</p>
                                                      <p><att>writtenLines</att> (written lines) specifies the number of written lines per column</p>
                                                      <p>If a single number is given, it applies uniformly across all relevant pages or columns. If two numbers are given, the value varies between the lower and upper bounds. If <att>columns</att> is omitted, it is assumed that each page has one column.</p>
                                                      <p>Describe the layout in one or more <gi>p</gi>, using the following conventions:</p>
                                                      <table rend="rules">
                                                        <row>
                                                          <cell><p>feature</p></cell>
                                                          <cell><p>preferred form</p></cell>
                                                          <cell><p>avoid</p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p>number of columns</p></cell>
                                                          <cell><p>one column | two columns</p></cell>
                                                          <cell><p>1 column, single column | 2 columns, double column</p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p>number of written lines</p></cell>
                                                          <cell><p>15 lines | 15-16 lines</p></cell>
                                                          <cell><p>fifteen lines | 15 to 16 lines</p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p>number of ruled lines</p></cell>
                                                          <cell><p>30 lines | 30-32 lines</p></cell>
                                                          <cell><p>thirty lines | 30 to 32 lines</p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p>ruling method</p></cell>
                                                          <cell><p>dry point | plummet | ink | pencil</p></cell>
                                                          <cell><p>hardpoint, leadpoint, pen</p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p>bounding lines</p></cell>
                                                          <cell><p>frame (all four sides of the text block)</p>
                                                            <p>single | double — vertical | horizontal bounding lines (not full frame)</p></cell>
                                                          <cell><p>1, 2, one, two
                                                              thirty horizontal lines</p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p>pricking</p></cell>
                                                          <cell><p>pricking marks visible in the inner | outer margin</p></cell>
                                                          <cell><p>do not record absence unless significant.</p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p>first line of text</p></cell>
                                                          <cell><p>above top line | below top line</p>
                                                            <p>(particularly useful for dating 13th century MSS)</p></cell>
                                                          <cell></cell>
                                                        </row>
                                                        <row>
                                                          <cell cols="3"><p><hi rend="italic">See the <ref target="https://guides.loc.gov/manuscript-facsimiles/glossary">Glossary</ref> in the Library of Congress Medieval and Renaissance Facsimiles and Incunables: A Resource Guide.</hi></p></cell>
                                                        </row>
                                                      </table>
                                                      <p>At a minimum level, you should provide the number of columns and written lines.</p>
                                                      <table rend="rules">
                                                        <row>
                                                          <cell><p><hi rend="bold">• Layout:</hi></p>
                                                            <p>One column, 22 lines.</p>
                                                            <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><layoutDesc>
<layout columns="1" writtenLines="22">
<p>One column, 22 lines.</p>
</layout>
</layoutDesc></egXML></p></cell>
                                                          </row>
                                                        </table>
                                                        <p>Measurements of the written or ruled space should be encoded using <gi>dimensions</gi> with <code>@type=</code> <val>written</val> and <val>ruled</val>, as appropriate.</p>
                                                        <table rend="rules">
                                                          <row>
                                                            <cell><p><hi rend="bold">• Layout:</hi></p>
                                                              <p>One column, 22 lines.</p>
                                                              <p>Written height: 170 mm, width: 110 mm.</p>
                                                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><layoutDesc>
<layout columns="1" writtenLines="22">
<p>One column, 22 lines.</p>
<dimensions type="written" unit="mm">
<height quantity="170">170</height>
<width quantity="110">110</width>
</dimensions>
</layout>
</layoutDesc></egXML></p>
                                                              <p rend="right"><hi rend="italic">The Pore Caitif</hi>: <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-ENGLISH-00087/1">English MS 87</ref></p></cell>
                                                          </row>
                                                          <row>
                                                            <cell><p><hi rend="bold">• Layout:</hi></p>
                                                              <p>One column, 26 lines, written below the top line.</p>
                                                              <p>Ruled in dark ink, with vertical and horizontal bounding lines forming a frame extending to the margins.</p>
                                                              <p>Pricking is visible on the outer margins of many leaves, for example 117r.</p>
                                                              <p>Written height: 110 mm, width: 75 mm.</p>
                                                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><layoutDesc>
<layout columns="1" writtenLines="22">
<p>One column, 26 lines, written below the top line.</p>
<p>Ruled in dark ink, with vertical and horizontal bounding lines forming a frame extending to the margins.</p>
<p>Pricking is visible on the outer margins of many leaves, for example <locus from="117r" to="117r">117r</locus>.</p>
<dimensions type="written" unit="mm">
<height quantity="110">110</height>
<width quantity="75">75</width>
</dimensions>
</layout>
</layoutDesc></egXML></p>
                                                              <p rend="right"><hi rend="italic">Later Version Wycliffe New Testament</hi>: <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-ENGLISH-00075/1">English MS 75</ref></p></cell>
                                                          </row>
                                                        </table>
                                                        <p><gi>dimensions</gi> should not be wrapped in <gi>p</gi>. It will be rendered independently, typically as a distinct display line in output systems such as MDC.</p>
                                                        <p>For early printed books, the concept of written lines does not apply, and ruling is not always present or relevant. As such, <att>ruledLines</att> and <att>writtenLines</att> are generally <hi rend="bold"><hi rend="italic">not</hi></hi> applicable. However, the number of columns should be encoded using <att>columns</att>, and, if possible, the number of lines should be included in the accompanying prose description.</p>
                                                        <table rend="rules">
                                                          <row>
                                                            <cell><p><hi rend="bold">• Layout:</hi></p>
                                                              <p>Printed in one column, 28-30 lines.</p>
                                                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<layoutDesc>
<layout columns="1">
<p>Printed in one column, 28-30 lines.</p>
</condition>]]></egXML></p>
                                                              <p rend="right"><hi rend="italic">Le terze rime di Dante</hi>: <ref target="https://www.digitalcollections.manchester.ac.uk/view/PR-ALDI-18873/1">18873</ref></p></cell>
                                                          </row>
                                                        </table>
                                                        <p>Where the number of written lines varies across the item, supply a range of values. The lower and upper bounds should be separated by a space rather than a hyphen (-) or dash (_). This indicates that the number of written lines varies between the two values.</p>
                                                        <table rend="rules">
                                                          <row>
                                                            <cell><p><hi rend="bold">• Layout:</hi></p>
                                                              <p>One column, 27-28 lines, written below the top line.</p>
                                                              <p>Ruled in plummet (leadpoint), with vertical and horizontal bounding lines forming a frame extending to the margins.</p>
                                                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><layoutDesc>
<layout columns="1" writtenLines="27 28">
<p>One column, 27-28 lines, written below the top line.</p>
<p>Ruled in plummet (leadpoint), with vertical and horizontal bounding lines forming a frame extending to the margins.</p>
</layout>
</layoutDesc></egXML></p>
                                                              <p rend="right"><hi rend="italic">Il Canzoniere di Petrarca e Le Rime di Dante</hi>: <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-ITALIAN-00001/1">Italian MS 1</ref></p></cell>
                                                          </row>
                                                        </table>
                                                        <p>Where the number of ruled lines per column differs from the number of written lines, use <att>ruledLines</att> and <att>writtenLines</att> to distinguish between the two.</p>
                                                        <table rend="rules">
                                                          <row>
                                                            <cell><p><hi rend="bold">• Layout:</hi></p>
                                                              <p>One column, 15–16 lines, written below the top line.</p>
                                                              <p>Ruled in very pale brown ink, visible in places, with 30-32 ruled lines and single vertical bounding lines extending to the margins.</p>
                                                              <p>Ruled height: 255 mm, width: 160 mm.</p>
                                                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><layoutDesc>
<layout columns="1" ruledLines="30 32" writtenLines="15 16">
<p>One column, 15–16 lines, written below the top line.</p>
<p>Ruled in very pale brown ink, visible in places, with 30-32 ruled lines and single vertical bounding lines extending to the margins.</p>
<dimensions type="ruled" unit="mm">
<height quantity="255">255</height>
<width quantity="160">160</width>
</dimensions>
</layout>
</layoutDesc></egXML></p>
                                                              <p rend="right"><hi rend="italic">Later Version Wycliffe New Testament</hi>: <ref target="https://www.digitalcollections.manchester.ac.uk/view/MS-ENGLISH-00075/1">English MS 75</ref></p></cell>
                                                          </row>
                                                        </table>
                                                        <p>Distinct differences may occur between sections of a manuscript that were nevertheless produced around the same time or within the same context, perhaps prompted by a change in scribal hand or by differences in how the quires were prepared for writing. In such cases, include as many <gi>layout</gi> entries as necessary, and use <gi>locus</gi> within the descriptive paragraph to specify the portions of the manuscript to which each layout applies.</p>
                                                        <table rend="rules">
                                                          <row>
                                                            <cell><p><hi rend="bold">• Layout:</hi></p>
                                                              <p>1r-220v: Two columns, 52 written lines. No pricking marks.</p>
                                                              <p>221r-350v: One column, 45 ruled lines and 33 written lines. Pricking marks visible along the outer margin, mostly cropped.</p>
                                                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><layoutDesc>
<layout columns="2" writtenLines="52">
<p><locus from="1r" to="220v">1r-220v</locus>: Two columns, 52 written lines. No pricking marks.</p>
</layout>
<layout columns="1" ruledLines="45" writtenLines="33">
<p><locus from="221r" to="350v">221r-350v</locus>: One column, 45 ruled lines and 33 written lines. Pricking marks visible along the outer margin, mostly cropped.</p>
</layout>
</layoutDesc></egXML></p></cell>
                                                            </row>
                                                          </table>
                                                          <p>After <gi>objectDesc</gi>, <gi>physDesc</gi> allows more specific descriptions of the item's physical, textual, and decorative features, including its written, printed, decorative, and notational content, together with any later additions, bindings, seals, and accompanying material.</p>
                                                          <p>The following elements may be included within <gi>physDesc</gi> whenever information is available:</p>
                                                          <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<teiHeader>
<fileDesc>|<titleStmt>|<publicationStmt>|<sourceDesc>
<msDesc>|<msIdentifier>|<msContents>
<physDesc>
<objectDesc/>
<handDesc>
<!-- Metadata describing the script in which an item is written -->
<!-- May contain <summary> -->
<handNote>
<!-- Metadata detailing the script and the hands of multiple scribes -->
<!-- Contains <term> -->
<!-- May contain <persName> within <name> -->
</handNote>
</handDesc>
<typeDesc>
<!-- Metadata describing the typefaces or other aspects of the printing of a source -->
<!-- May contain <summary>
<typeNote>
<!-- Metadata detailing the typefaces or typographic settings -->
<!-- Contains <term> -->
<!-- May contain <persName> within <name> -->
</typeNote>
</typeDesc>
<musicNotation>
<!-- Metadata notated music present in the item -->
<!-- Contains <p> -->
</musicNotation>
<decoDesc>
<!-- Metadata describing the script in which an item is written -->
<!-- May contain <summary>
<decoNote>
<!-- Metadata detailing the script and the hands of multiple scribes -->
<!-- May contain <summary> | <persName> within <name> -->
</decoNote>
</decoDesc>
<additions>
<!-- Metadata describing additions to script, entered in later hands -->
<!-- Contains <p> -->
</additions>
<bindingDesc>
<!-- Metadata describing the binding of an item -->
<binding>
<!-- Metadata detailing all aspects of a binding -->
<!-- Contains <dimensions> -->
<!-- May contain <decoNote> | <condition> | <term> | <persName> within <name> -->
</binding>
</bindingDesc>
<sealDesc>
<!-- Metadata describing the seal attached to an item -->
<!-- May contain <summary>
<seal>
<!-- Metadata detailing all aspects of a seal -->
<!-- May contain dimensions | <decoNote> | <condition> | <persName> within <name> -->
</seal>
</sealDesc>
<accMat>
<!-- Metadata about material that are not part of the original item -->
<!-- Contains <p> -->
</accMat>
</physDesc>
<history>|<additional>
</msDesc>|</sourceDesc>|</fileDesc>|<encodingDesc/>|<profileDesc>|<revisionDesc>
</teiHeader>]]></egXML></p>
                                                        </div>
                                                        <div xml:id="handDesc">
                                                          <head><code>&lt;handDesc&gt;</code> | description of hands</head>
                                                          <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-handDesc.html"><gi>handDesc</gi></ref> <hi rend="italic">(description of hands) contains a description of all the different hands used in a manuscript or other object.</hi></p>
                                                          <p rend="displayLabel">MDC display label — <hi rend="bold">Script</hi></p>
                                                          <p><gi>handDesc</gi> is used to record the description of the script found within a manuscript or other handwritten document. It provides structured information about the number, identity, and characteristics of the hands (i.e. individual scribes or writers) responsible for the written content.</p>
                                                          <p>The number of distinct hands identified in a manuscript should always be encoded using <att>hands</att> on <gi>handDesc</gi>, whether there is one hand or several. Further descriptive detail may be supplied using one or more <gi>handNote</gi>.</p>
                                                          <p rend="attHead"><code>@hands</code></p>
                                                          <p><att>hands</att> (hands) specifies the number of distinct hands identified within the manuscript</p>
                                                          <p><att>hands</att> should take values such as <val>1</val>, <val>2</val>, <val>3</val>, and so on, representing the number of hands involved in the original production and should <hi rend="bold"><hi rend="italic">not</hi></hi> include later additions or annotations.</p>
                                                          <p><gi>handDesc</gi> may include <gi>summary</gi> with one or more <gi>p</gi> providing a general account of the scripts or scribes. This must be followed by one or more <gi>handNote</gi>, each describing a particular hand or group of hands.</p>
                                                        </div>
                                                        <div xml:id="handNote">
                                                          <head><code>&lt;handNote&gt;</code> | note on hand</head>
                                                          <p rend="definition"><ref target="https://tei-c.org/release/doc/tei-p5-doc/en/html/ref-handNote.html"><gi>handNote</gi></ref> <hi rend="italic">(note on hand) describes a particular style or hand distinguished within a manuscript.</hi></p>
                                                          <p><gi>handNote</gi> within <gi>handDesc</gi> typically includes details such as the script style and the extent of the hand, scribe attribution where known, distinctive features of the writing, and medium. These details may be encoded using <att>scope</att>, <att>script</att>, and <att>medium</att>, together with descriptive prose in <gi>p</gi>. The script may be further characterised using <code>&lt;term type="script"&gt;</code>.</p>
                                                          <p rend="attHead"><code>@scope</code></p>
                                                          <p><code>scope</code> specifies how widely this hand is used in the manuscript</p>
                                                          <p>The following values should be used:</p>
                                                          <p><val>sole</val> only this hand is used throughout the manuscript</p>
                                                          <p><val>major</val> this hand is used through most of the manuscript</p>
                                                          <p><val>minor</val> this hand is used occasionally in the manuscript</p>
                                                          <p rend="attHead"><code>@script</code></p>
                                                          <p><att>script</att> characterises the particular script or writing style used by this hand</p>
                                                          <p><att>script</att> is used for consistent, high-level script classification, following approved nomenclature.</p>
                                                          <p>In Latin-script manuscripts, <att>script</att> values are typically Latin-derived terms that identify the palaeographical class of writing, such as textualis, cursiva, or humanistica. <att>script</att> functions as a controlled, language-neutral identifier for the script family. Its values must always be encoded in lowercase, without accents or spaces, using camelCase only to join logical parts of the term. For example, <val>textualisNorthern</val> | <val>textualisSouthern</val> | <val>cursivaAntiquior</val>.</p>
                                                          <p>Where possible, the accompanying <code>&lt;term type="script"&gt;</code> should repeat the same Latin family root and may include a simple descriptive qualifier, for example, textualis quadrata, textualis rotunda, cursiva libraria, humanistica cursiva. Traditional script terms such as anglicana, anglicana formata, bâtarde, and secretary may also be used as <code>&lt;term type="script"&gt;</code> values, provided they are compatible with the script family identified in <att>script</att>. For instance, <att>script</att>=<val>cursivaAntiquior</val> with <code>&lt;term type="script"&gt;anglicana&lt;/term&gt;</code>. It must contain only the script term itself.</p>
                                                          <p>Avoid using vague or hybrid English terms such as bastard secretary, Gothic script, Gothic bookhand in either <att>script</att> or <code>&lt;term type="script"&gt;</code>. Consistency in terminology is important. The formal script commonly referred to as textualis, textura, or Gothic bookhand represents a single script type. These terms are synonymous, and the preferred term is textualis.</p>
                                                          <p>In <code>&lt;term type="script"&gt;</code>, capitalise script names that derive from personal names, ethnonyms, geographic or regional designations, languages, or language-derived adjectives, such as Caroline, Beneventan, Tamil, Ethiopic, Ashkenazi or Rashi. Use lowercase for generic script-style or typological terms, including minuscule, uncial, cursiva, naskh, nastaʿlīq, textualis or semi-square.</p>
                                                          <p>Suggested values for Latin-script manuscripts are:</p>
                                                          <table rend="rules">
                                                            <row>
                                                              <cell><p><att>script</att></p></cell>
                                                              <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<term type="script">]]></egXML></p></cell>
                                                            </row>
                                                            <row>
                                                              <cell><p><val>capitalSquare</val></p>
                                                                <p rend="right">square capitals</p></cell>
                                                              <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">square capitals</term></egXML></p>
                                                              <p>Narrower Roman capitals.</p></cell>
                                                          </row>
                                                          <row>
                                                            <cell><p><val>uncial</val></p>
                                                              <p rend="right">uncial</p></cell>
                                                            <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">uncial</term></egXML></p>
                                                            <p>Rounded majuscule script.</p></cell>
                                                        </row>
                                                        <row>
                                                          <cell><p><val>halfuncial</val></p>
                                                            <p rend="right">half-uncial</p></cell>
                                                          <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">half-uncial</term></egXML></p>
                                                          <p>Transitional majuscule. Combines uncial and minuscule features.</p></cell>
                                                      </row>
                                                      <row>
                                                        <cell><p><val>majuscule</val></p>
                                                          <p rend="right">majuscule</p></cell>
                                                        <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">majuscule</term></egXML></p>
                                                        <p>Unspecified majuscule hand, not assignable to a subtype.</p></cell>
                                                    </row>
                                                    <row>
                                                      <cell><p><val>majusculeInsular</val></p>
                                                        <p rend="right">Insular majuscule</p></cell>
                                                      <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">Insular majuscule</term></egXML></p>
                                                      <p>Formal Insular bookhand.</p></cell>
                                                  </row>
                                                  <row>
                                                    <cell><p><val>minusculeInsular</val></p>
                                                      <p rend="right">Insular minuscule</p></cell>
                                                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">Insular minuscule</term></egXML></p>
                                                    <p>Standard Insular bookhand.</p></cell>
                                                </row>
                                                <row>
                                                  <cell><p><val>minusculeCaroline</val></p>
                                                    <p rend="right">Caroline minuscule</p></cell>
                                                  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">Caroline minuscule</term></egXML></p>
                                                  <p>Clear, rounded Carolingian bookhand, revived in Renaissance humanistic scripts.</p></cell>
                                              </row>
                                              <row>
                                                <cell><p><val>minusculeVernacular</val></p>
                                                  <p rend="right">vernacular minuscule</p></cell>
                                                <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">vernacular minuscule</term></egXML></p>
                                                <p>English vernacular script influenced by Caroline minuscule.</p></cell>
                                            </row>
                                            <row>
                                              <cell><p><val>minusculeBeneventan</val></p>
                                                <p rend="right">Beneventan minuscule</p></cell>
                                              <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">Beneventan minuscule</term></egXML></p>
                                              <p>Southern Italian minuscule, used in Benevento and Monte Cassino.</p></cell>
                                          </row>
                                          <row>
                                            <cell><p><val>minusculeVisigothic</val></p>
                                              <p rend="right">Visigothic minuscule</p></cell>
                                            <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">Visigothic minuscule</term></egXML></p>
                                            <p>Iberian Latin minuscule.</p></cell>
                                        </row>
                                        <row>
                                          <cell><p><val>minuscule</val></p>
                                            <p rend="right">minuscule</p></cell>
                                          <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">minuscule</term></egXML></p>
                                          <p>Unspecified minuscule hand, not assignable to a subtype.</p></cell>
                                      </row>
                                      <row>
                                        <cell><p><val>protogothic</val></p>
                                          <p rend="right">protogothic</p></cell>
                                        <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">protogothic</term></egXML></p>
                                        <p>Transitional hand between Caroline and Gothic.</p></cell>
                                    </row>
                                    <row>
                                      <cell><p><val>textualisNorthern</val></p>
                                        <p rend="right">textualis quadrata</p>
                                        <p rend="right">textualis semi-quadrata</p>
                                        <p rend="right">textualis prescissa</p>
                                        <p rend="right">textualis libraria</p>
                                        <p rend="right">textualis currens</p>
                                        <p rend="right">textualis rotunda</p></cell>
                                      <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">textualis quadrata</term></egXML></p>
                                      <p>Northern Gothic bookhand with diamond-shaped feet on minims (pedes).</p>
                                      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">textualis semi-quadrata</term></egXML></p>
                                      <p>Northern Gothic variant with partly developed feet. Intermediate between quadrata and prescissa.</p>
                                      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">textualis prescissa</term></egXML></p>
                                      <p>Northern gothic variant with sine pedibus (without feet); minims cut flat along the baseline.</p>
                                      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">textualis libraria</term></egXML></p>
                                      <p>Regular bookhand of northern textualis.</p>
                                      <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">textualis currens</term></egXML></p>
                                      <p>Rapid or informal northern textualis. Transitional, towards cursiva.</p></cell>
                                  </row>
                                  <row>
                                    <cell><p><val>textualisSouthern</val></p>
                                      <p rend="right">textualis rotunda</p></cell>
                                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">textualis rotunda</term></egXML></p>
                                    <p>Southern Gothic bookhand (Italy | Iberia) with rounded letterforms.</p></cell>
                                </row>
                                <row>
                                  <cell><p><val>semitextualis</val></p>
                                    <p rend="right">semitextualis</p></cell>
                                  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">semitextualis</term></egXML></p>
                                  <p>Transitional class between textualis and cursiva. Moderately angular.</p></cell>
                              </row>
                              <row>
                                <cell cols="2"><p>Script classification is not primarily about geography. It's about the style of the handwriting.</p>
                                  <p><code>textualisNorthern</code> France, England, Germany, Angular, compressed, vertical</p>
                                  <p><code>textualisSouthern</code> Italy, Iberia, Southern France, Rounded, open forms (rotunda)</p></cell>
                              </row>
                              <row>
                                <cell><p><val>cursivaAntiquior</val></p>
                                  <p rend="right">cursiva antiquior</p>
                                  <p rend="right">anglicana</p>
                                  <p rend="right">anglicana formata</p>
                                  <p rend="right">cursiva libraria</p>
                                  <p rend="right">cursiva currens</p></cell>
                                <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">cursiva antiquior</term></egXML></p>
                                <p>Early Gothic cursive, precursor of later Gothic cursives.</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">anglicana</term></egXML></p>
                                <p>English variety of cursiva antiquior.</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">anglicana formata</term></egXML></p>
                                <p>Formalised anglicana. A regularised book or display hand within cursiva antiquior.</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">cursiva libraria</term></egXML></p>
                                <p>Standard “library” or formal bookhand of cursiva antiquior.</p>
                                <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">cursiva currens</term></egXML></p>
                                <p>Rapid, informal cursive of cursiva antiquior.</p></cell>
                            </row>
                            <row>
                              <cell><p><val>cursiva</val></p>
                                <p rend="right">cursiva</p>
                                <p rend="right">cursiva libraria</p>
                                <p rend="right">bâtarde</p>
                                <p rend="right">secretary</p></cell>
                              <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">cursiva</term></egXML></p>
                              <p>Later Gothic cursive. Includes a wide range of regional styles.</p>
                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">cursiva libraria</term></egXML></p>
                              <p>Formal bookhand variety of cursiva, known as Gothica cursiva libraria.</p>
                              <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">bâtarde</term></egXML></p>
                              <p>Formal French-Burgundian variety of cursiva. Also known as bastarda or lettre bâtarde.</p></cell>
                          </row>
                          <row>
                            <cell><p><val>hybrida</val></p>
                              <p rend="right">hybrida</p></cell>
                            <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">hybrida</term></egXML></p>
                            <p>Fusion of textualis and cursiva features.</p></cell>
                        </row>
                        <row>
                          <cell><p><val>gothicoAntiqua</val></p>
                            <p rend="right">gothico-antiqua</p></cell>
                          <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">gothico-antiqua</term></egXML></p>
                          <p>Transitional fifteenth-century Italian script combining Gothic textualis and humanistic features; also known as gothico-humanistica or fere-humanistica.</p></cell>
                      </row>
                      <row>
                        <cell><p><val>humanistica</val></p>
                          <p rend="right">humanistica</p>
                          <p rend="right">humanistica textualis</p>
                          <p rend="right">humanistica semitextualis</p>
                          <p rend="right">humanistica cursiva</p></cell>
                        <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">humanistica</term></egXML></p>
                        <p>General or indeterminate humanist hand. Use when the script is recognisably humanistic but not assignable to a subtype.</p>
                        <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">humanistica textualis</term></egXML></p>
                        <p>Renaissance revival of Caroline minuscule.</p>
                        <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">humanistica semitextualis</term></egXML></p>
                        <p>Semi-formal humanist book hand, intermediate between textual and cursive forms.</p>
                        <p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">humanistica cursiva</term></egXML></p>
                        <p>Humanist chancery cursive (cancelleresca all’italiana). Prototype of italic script and type.</p></cell>
                    </row>
                    <row>
                      <cell><p><val>kurrent</val></p>
                        <p rend="right">kurrent</p></cell>
                      <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">kurrent</term></egXML></p>
                      <p>German cursive (Kurrentschrift), 16th-20th century. Distinct from Latin cursiva.</p></cell>
                  </row>
                  <row>
                    <cell><p><val>other</val></p></cell>
                    <cell><p><code>N/A</code></p>
                      <p>For clearly identifiable scripts outside the current controlled vocabulary.</p></cell>
                  </row>
                  <row>
                    <cell><p><val>unknown</val></p></cell>
                    <cell><p><code>N/A</code></p>
                      <p>Used when the script cannot be securely identified.</p></cell>
                  </row>
                </table>
                <p>The classification for early scripts is based on Brown (1990) with modifications, for gothic scripts on Derolez (2003), for humanistic scripts on Derolez (2011).</p>
                <p>Suggested values for non-Latin manuscripts are:</p>
                <table rend="rules">
                  <row>
                    <cell><p><att>script</att></p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><![CDATA[<term type="script">]]></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>naskh</val></p>
                      <p rend="right">naskh</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">naskh</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>nastaliq</val></p>
                      <p rend="right">nastaʿlīq</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">nastaʿlīq </term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>taliq</val></p>
                      <p rend="right">taʿlīq</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">taʿlīq</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>shikastah</val></p>
                      <p rend="right">shikastah</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">shikastah</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>divani</val></p>
                      <p rend="right">dīvānī</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">dīvānī</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>thuluth</val></p>
                      <p rend="right">thuluth</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">thuluth</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>rayhani</val></p>
                      <p rend="right">rayḥānī</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">rayḥānī</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>ruqah</val></p>
                      <p rend="right">ruqʿah</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">ruqʿah</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>riqa</val></p>
                      <p rend="right">riqa</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">riqā</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>tughra</val></p>
                      <p rend="right">ṭughrā</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">ṭughrā</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>ajami</val></p>
                      <p rend="right">ʿajamī</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">ʿajamī</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>maghribi</val></p>
                      <p rend="right">maghribī</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">maghribī</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>kufic</val></p>
                      <p rend="right">kufic</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">kufic</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>muhaqqaq</val></p>
                      <p rend="right">muḥaqqaq</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">muḥaqqaq</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>siyaq</val></p>
                      <p rend="right">sīyāq</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">sīyāq</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>eastSyriac</val></p>
                      <p rend="right">East Syriac</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">East Syriac</term></egXML></p></cell>
                  </row>
                  <row>
                    <cell><p><val>estrangela</val></p>
                      <p rend="right">estrangela</p></cell>
                    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">estrangela</term></egXML></p>
                    <p>estrangela Syriac script</p></cell>
                </row>
                <row>
                  <cell><p><val>serto</val></p>
                    <p rend="right">serto</p></cell>
                  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">serto</term></egXML></p>
                  <p>serto Syriac script</p></cell>
              </row>
              <row>
                <cell><p><val>ethiopic</val></p>
                  <p rend="right">Ethiopic</p></cell>
                <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">Ethiopic</term></egXML></p>
                <p>Ethiopic script | Geʽez language</p></cell>
            </row>
            <row>
              <cell><p><val>asomtavruli</val></p>
                <p rend="right">asomtavruli</p></cell>
              <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">asomtavruli</term></egXML></p>
              <p>asomtavruli Georgian script</p></cell>
          </row>
          <row>
            <cell><p><val>nuskhuri</val></p>
              <p rend="right">nuskhuri</p></cell>
            <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">nuskhuri</term></egXML></p>
            <p>nuskhuri Georgian script</p></cell>
        </row>
        <row>
          <cell><p><val>mkhedruli</val></p>
            <p rend="right">mkhedruli</p></cell>
          <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">mkhedruli</term></egXML></p>
          <p>mkhedruli Georgian script</p></cell>
      </row>
      <row>
        <cell><p><val>erkatagir</val></p>
          <p rend="right">erkatʿagir</p></cell>
        <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">erkatʿagir </term></egXML></p>
        <p>erkatʿagir Armenian script</p></cell>
    </row>
    <row>
      <cell><p><val>bolorgir</val></p>
        <p rend="right">bolorgir</p></cell>
      <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">bolorgir</term></egXML></p>
      <p>bolorgir Armenian script</p></cell>
  </row>
  <row>
    <cell><p><val>notrgir</val></p>
      <p rend="right">nōtrgir</p></cell>
    <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">nōtrgir</term></egXML></p>
    <p>nōtrgir Armenian script</p></cell>
</row>
<row>
  <cell><p><val>devanagari</val></p>
    <p rend="right">devanāgarī</p></cell>
  <cell><p><egXML xmlns="http://www.tei-c.org/ns/Examples"><term type="script">devanāgarī</term></egXML></p></cell>
</row>
<row>
